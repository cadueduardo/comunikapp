# Shell scripts: always LF (evita erro de \r no Linux)
*.sh text eol=lf

# Documentation: keep diffs stable across Windows/Linux
*.md text eol=lf

# Dependencies preserve the bytes published by their maintainers
node_modules/** -text
**/node_modules/** -text

# Cron files: must be LF (Linux cron rejeita CRLF silenciosamente)
deploy/cron/* text eol=lf

# Nginx/fail2ban configs: precisam ser LF para o parser do Linux
deploy/nginx/*.conf text eol=lf
deploy/fail2ban/*.local text eol=lf
