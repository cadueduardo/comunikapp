# =============================================================================
# ComunikApp Frontend - .env.production (template)
# =============================================================================
# Salvar em frontend/.env.production na VPS.
# As variáveis NEXT_PUBLIC_* são embutidas no bundle JS - NÃO colocar segredos aqui.

# URL pública da API (passa pelo Nginx + SSL)
NEXT_PUBLIC_API_URL="https://api.comunikapp.com.br"
NEXT_PUBLIC_BACKEND_URL="https://api.comunikapp.com.br"

# URL publica do site (Open Graph / preview ao compartilhar link no WhatsApp)
NEXT_PUBLIC_SITE_URL="https://comunikapp.com.br"

# URL interna usada pelas API Routes do Next como proxy server-side.
# Aponta para 127.0.0.1 porque o backend escuta apenas no loopback.
BACKEND_URL="http://127.0.0.1:4001"

# Porta do Next em produção (Nginx faz proxy_pass para 127.0.0.1:3001)
PORT=3001
HOST=127.0.0.1
NODE_ENV=production

# Versão global da plataforma (embutida no build; mesma para todas as lojas)
# NEXT_PUBLIC_GIT_SHA e NEXT_PUBLIC_APP_VERSION sao preenchidos automaticamente
# em cada `npm run build` (git SHA + versao do package.json). Nao e necessario
# editar estas linhas a cada deploy — use apenas se quiser sobrescrever manualmente.
# NEXT_PUBLIC_APP_VERSION="1.0.0"
# NEXT_PUBLIC_GIT_SHA=""
