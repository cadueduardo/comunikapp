// ==========================================
// MÓDULO PCP - SETORES PRODUTIVOS
// ==========================================

model SetorProdutivo {
  id                       String   @id @default(cuid())
  loja_id                  String
  nome                     String
  descricao                String?  @db.Text
  cor                      String   @default("#3B82F6") // Cor HEX para identificação visual
  ativo                    Boolean  @default(true)
  ordem                    Int      @default(0) // Ordem de exibição
  horas_produtivas_mensais Int? // Horas produtivas mensais deste setor (rateio)
  percentual_rateio_geral  Decimal? @db.Decimal(5, 2) // % dos custos gerais (opcional)
  criado_em                DateTime @default(now())
  atualizado_em            DateTime @updatedAt

  // Relacionamentos
  loja             loja                     @relation(fields: [loja_id], references: [id])
  workflow_setores WorkflowSetor[]
  instancias_setor WorkflowInstanciaSetor[]
  maquinas         maquina[]
  funcoes          funcao[]
  servicos_manuais servico_manual[]
  custos_indiretos custoindireto[]

  @@unique([loja_id, nome])
  @@index([loja_id, ativo])
  @@index([ordem])
  @@map("setores_produtivos")
}

model WorkflowSetor {
  id             String   @id @default(cuid())
  workflow_id    String
  setor_id       String
  ordem          Int      @default(0)
  tempo_estimado Int? // em minutos
  obrigatorio    Boolean  @default(true)
  criado_em      DateTime @default(now())

  // Relacionamentos
  workflow WorkflowOS     @relation(fields: [workflow_id], references: [id], onDelete: Cascade)
  setor    SetorProdutivo @relation(fields: [setor_id], references: [id])

  @@unique([workflow_id, setor_id])
  @@index([workflow_id])
  @@index([setor_id])
  @@map("workflow_setores")
}

model WorkflowCategoria {
  id            String   @id @default(cuid())
  loja_id       String
  nome          String
  descricao     String?  @db.Text
  workflow_id   String
  criterios     String?  @db.LongText
  prioridade    Int      @default(0)
  ativo         Boolean  @default(true)
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  loja     loja                     @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  workflow WorkflowOS               @relation("WorkflowCategoriaWorkflow", fields: [workflow_id], references: [id], onDelete: Cascade)
  regras   WorkflowCategoriaRegra[]

  @@unique([loja_id, nome])
  @@index([workflow_id])
  @@index([loja_id, ativo])
  @@map("workflow_categorias")
}

model WorkflowCategoriaRegra {
  id            String   @id @default(cuid())
  categoria_id  String
  tipo          String
  valor         String
  obrigatoria   Boolean  @default(true)
  prioridade    Int      @default(0)
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  categoria WorkflowCategoria @relation(fields: [categoria_id], references: [id], onDelete: Cascade)

  @@index([categoria_id])
  @@map("workflow_categoria_regras")
}

model WorkflowInstanciaSetor {
  id                    String    @id @default(cuid())
  loja_id               String
  workflow_id           String
  workflow_instancia_id String
  setor_id              String
  item_os_id            String? // Opcional - pode ser por OS ou por item específico
  status                String    @default("PENDENTE") // PENDENTE, EM_ANDAMENTO, CONCLUIDA, PAUSADA, CANCELADA
  ordem                 Int       @default(0)
  data_inicio           DateTime?
  data_conclusao        DateTime?
  operador_id           String?
  tempo_estimado        Int? // em minutos
  tempo_real            Int? // em minutos
  observacoes           String?   @db.Text
  criado_em             DateTime  @default(now())
  atualizado_em         DateTime  @updatedAt

  // Relacionamentos
  loja               loja              @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  workflow           WorkflowOS        @relation(fields: [workflow_id], references: [id], onDelete: Restrict)
  workflow_instancia WorkflowInstancia @relation(fields: [workflow_instancia_id], references: [id], onDelete: Cascade)
  setor              SetorProdutivo    @relation(fields: [setor_id], references: [id])
  item_os            ItemOS?           @relation(fields: [item_os_id], references: [id])
  operador           usuario?          @relation(fields: [operador_id], references: [id])
  @@index([loja_id, status])
  @@index([workflow_id])
  @@index([workflow_instancia_id])
  @@index([setor_id])
  @@index([item_os_id])
  @@index([status])
  @@index([operador_id])
  @@map("workflow_instancia_setor")
}

