  @@index([loja_id, os_id])
  @@index([loja_id, status_financeiro])
  @@index([loja_id, status_financeiro, criado_em])
  @@index([os_id])
  @@index([item_instalacao_id])
  @@index([os_aditiva_id])
  @@index([tipo])
  @@index([criado_em])
  @@map("ocorrencias_instalacao")
}

model OrcamentoAditivoInstalacao {
