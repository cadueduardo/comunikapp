// ===== MÓDULO OS (ORDENS DE SERVIÇO) =====

model OrdemServico {
  id                 String    @id @default(cuid())
  numero             String    // Autonumeração sequencial
  loja_id            String
  cliente_id         String
  orcamento_id       String?   // Opcional - vínculo com orçamento aprovado
  data_abertura      DateTime  @default(now())
  data_prazo         DateTime?
  status             String    @default("FILA")
  responsavel_id     String?
  observacoes        String?   @db.Text
  criado_em          DateTime  @default(now())
  atualizado_em      DateTime  @updatedAt

  // Campos específicos do produto/serviço
  nome_servico       String
  descricao          String?   @db.Text
  quantidade         Decimal   @db.Decimal(10, 2)
  parametros_tecnicos String?  @db.LongText // JSON com medidas, cores, etc
  insumos_calculados  String?  @db.LongText // JSON dos insumos necessários
  materiais_disponivel Boolean @default(false)

  // Campos de aprovação técnica (checkpoint pre-produção)
  aprovacao_tecnica_status String?  @default("PENDENTE") // PENDENTE, APROVADA, REJEITADA
  aprovacao_tecnica_por    String?  // usuario_id do aprovador
  aprovacao_tecnica_em     DateTime? // data da aprovação
  aprovacao_tecnica_obs    String?  @db.Text // observações da aprovação

  // Campos de agendamento de instalação
  data_instalacao_agendada DateTime? // data agendada para instalação (após contato com cliente)
  observacoes_instalacao   String?  @db.Text // observações para coordenação de instalação externa

  // Campos para diferenciação OS Direta vs Interna
  tipo_os                  String   @default("COMERCIAL") // COMERCIAL, INTERNA
  origem_os                String?  // ORCAMENTO, DIRETA, INTERNA
  prioridade               String   @default("NORMAL") // URGENTE, ALTA, NORMAL, BAIXA
  
  // Campos específicos para OS Interna
  departamento_solicitante String?  // Departamento que solicitou a OS interna
  centro_custo             String?  // Centro de custo para OS interna
  projeto_interno          String?  // Projeto interno relacionado
  aprovacao_gerencial      String?  @default("PENDENTE") // PENDENTE, APROVADA, REJEITADA
  aprovacao_gerencial_por  String?  // usuario_id do aprovador gerencial
  aprovacao_gerencial_em   DateTime? // data da aprovação gerencial
  aprovacao_gerencial_obs  String?  @db.Text // observações da aprovação gerencial
  
  // Campos específicos para OS Comercial
  valor_orcado             Decimal? @db.Decimal(12, 2) // Valor do orçamento aprovado
  valor_realizado          Decimal? @db.Decimal(12, 2) // Valor real gasto na produção
  margem_lucro_real        Decimal? @db.Decimal(5, 2) // Margem de lucro real obtida
  data_entrega_cliente     DateTime? // Data real de entrega ao cliente
  satisfacao_cliente       Int?     // Nota de satisfação do cliente (1-5)
  observacoes_cliente      String?  @db.Text // Observações do cliente sobre o serviço
  
  // Campos de controle e auditoria
  criado_por               String?  // usuario_id que criou a OS
  modificado_por           String?  // usuario_id que fez a última modificação
  motivo_modificacao       String?  @db.Text // Motivo da última modificação
  versao                   Int      @default(1) // Controle de versão da OS

  // Relacionamentos
  loja               loja      @relation(fields: [loja_id], references: [id])
  cliente            cliente   @relation(fields: [cliente_id], references: [id])
  orcamento          orcamento? @relation(fields: [orcamento_id], references: [id])

  // Relacionamentos internos do módulo
  itens              ItemOS[]
  movimentacoes      MovimentacaoOS[]
  checklists         ChecklistOS[]
  workflow_instancia WorkflowInstancia?
  apontamentos       Apontamento[]
  logs               OrdemServicoLog[]
  execucoes_regras   ExecucaoRegra[]
  
  // Relacionamentos Arte & Aprovação
  artes_versoes      ArteVersao[]
  artes_mensagens    ArteMensagem[]

  @@unique([loja_id, numero])
  @@index([loja_id, status])
  @@index([cliente_id])
  @@index([responsavel_id])
  @@index([data_abertura])
  @@index([aprovacao_tecnica_status])
  @@index([aprovacao_tecnica_por])
  @@index([data_instalacao_agendada])
  @@index([tipo_os])
  @@index([origem_os])
  @@index([prioridade])
  @@index([departamento_solicitante])
  @@index([centro_custo])
  @@index([aprovacao_gerencial])
  @@index([aprovacao_gerencial_por])
  @@index([data_entrega_cliente])
  @@index([criado_por])
  @@index([modificado_por])
  @@index([versao])
  @@map("ordens_servico")
}

model ItemOS {
  id                 String    @id @default(cuid())
  os_id              String
  produto_servico    String
  quantidade         Decimal   @db.Decimal(10, 2)
  parametros_tecnicos String?  @db.LongText // JSON
  insumos_necessarios String?  @db.LongText // JSON calculado
  materiais_disponivel Boolean @default(false)
  observacoes        String?   @db.Text
  criado_em          DateTime  @default(now())
  
  // PRAZOS DO PRODUTO
  data_inicio_producao   DateTime?  // Quando deve iniciar produção
  data_prazo_produto     DateTime?  // Prazo específico deste produto
  
  // LIBERAÇÃO PCP
  status_liberacao_pcp   String?    @default("PENDENTE") // PENDENTE, LIBERADO, EM_PRODUCAO, CONCLUIDO
  liberado_pcp_por       String?    // usuario_id
  liberado_pcp_em        DateTime?  // Data de liberação
  
  // PRIORIDADE E ORDEM
  prioridade_produto     String?    @default("NORMAL") // URGENTE, ALTA, NORMAL, BAIXA
  ordem_producao         Int?       // Ordem de produção (1, 2, 3...)

  os                 OrdemServico @relation(fields: [os_id], references: [id], onDelete: Cascade)
  instancias_setor   WorkflowInstanciaSetor[]

  @@index([os_id])
  @@index([status_liberacao_pcp])
  @@index([data_inicio_producao])
  @@map("itens_os")
}

model WorkflowOS {
  id                 String    @id @default(cuid())
  loja_id            String
  nome               String
  descricao          String?   @db.Text
  etapas             String    @db.LongText // JSON das etapas configuráveis
  ativo              Boolean   @default(true)
  sequencial         Boolean   @default(true) // true = sequencial, false = paralelo
  criado_em          DateTime  @default(now())
  atualizado_em      DateTime  @updatedAt

  loja               loja      @relation(fields: [loja_id], references: [id])
  instancias         WorkflowInstancia[]
  workflow_setores   WorkflowSetor[]
  categorias         WorkflowCategoria[] @relation("WorkflowCategoriaWorkflow")

  @@unique([loja_id, nome])
  @@index([loja_id, ativo])
  @@map("workflows_os")
}

model MovimentacaoOS {
  id                 String    @id @default(cuid())
  os_id              String
  etapa_anterior     String?
  etapa_atual        String
  usuario_id         String
  data_movimentacao  DateTime  @default(now())
  observacoes        String?   @db.Text
  anexos             String?   @db.LongText // JSON de anexos
  ip_origem          String?
  user_agent         String?

  os                 OrdemServico @relation(fields: [os_id], references: [id], onDelete: Cascade)

  @@index([os_id])
  @@index([data_movimentacao])
  @@index([usuario_id])
  @@map("movimentacoes_os")
}

model ChecklistOS {
  id                 String    @id @default(cuid())
  os_id              String
  etapa              String
  item_checklist     String
  concluido          Boolean   @default(false)
  usuario_id         String?
  data_conclusao     DateTime?
  observacoes        String?   @db.Text
  obrigatório        Boolean   @default(true)
  ordem              Int       @default(0)

  os                 OrdemServico @relation(fields: [os_id], references: [id], onDelete: Cascade)

  @@index([os_id, etapa])
  @@index([concluido])
  @@map("checklists_os")
