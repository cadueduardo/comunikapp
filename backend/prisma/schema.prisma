// ==========================================
// MÓDULO PCP - SETORES PRODUTIVOS
// ==========================================

model SetorProdutivo {
  id                      String    @id @default(cuid())
  loja_id                 String
  nome                    String
  descricao               String?   @db.Text
  cor                     String    @default("#3B82F6") // Cor HEX para identificação visual
  ativo                   Boolean   @default(true)
  ordem                   Int       @default(0) // Ordem de exibição
  horas_produtivas_mensais Int?     // Horas produtivas mensais deste setor (rateio)
  percentual_rateio_geral Decimal?  @db.Decimal(5, 2) // % dos custos gerais (opcional)
  criado_em               DateTime  @default(now())
  atualizado_em           DateTime  @updatedAt

  // Relacionamentos
  loja               loja      @relation(fields: [loja_id], references: [id])
  workflow_setores   WorkflowSetor[]
  instancias_setor   WorkflowInstanciaSetor[]
  maquinas           maquina[]
  funcoes            funcao[]
  servicos_manuais   servico_manual[]
  custos_indiretos   custoindireto[]

  @@unique([loja_id, nome])
  @@index([loja_id, ativo])
  @@index([ordem])
  @@map("setores_produtivos")
}

model WorkflowSetor {
  id                 String    @id @default(cuid())
  workflow_id        String
  setor_id           String
  ordem              Int       @default(0)
  tempo_estimado     Int?      // em minutos
  obrigatorio        Boolean   @default(true)
  criado_em          DateTime  @default(now())

  // Relacionamentos
  workflow           WorkflowOS @relation(fields: [workflow_id], references: [id], onDelete: Cascade)
  setor              SetorProdutivo @relation(fields: [setor_id], references: [id])

  @@unique([workflow_id, setor_id])
  @@index([workflow_id])
  @@index([setor_id])
  @@map("workflow_setores")
}

model WorkflowCategoria {
  id            String   @id @default(cuid())
  loja_id       String
  nome          String
  descricao     String?  @db.Text
  workflow_id   String
  criterios     String?  @db.LongText
  prioridade    Int      @default(0)
  ativo         Boolean  @default(true)
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  loja     loja       @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  workflow WorkflowOS @relation("WorkflowCategoriaWorkflow", fields: [workflow_id], references: [id], onDelete: Cascade)
  regras   WorkflowCategoriaRegra[]

  @@unique([loja_id, nome])
  @@index([workflow_id])
  @@index([loja_id, ativo])
  @@map("workflow_categorias")
}

model WorkflowCategoriaRegra {
  id            String   @id @default(cuid())
  categoria_id  String
  tipo          String
  valor         String
  obrigatoria   Boolean  @default(true)
  prioridade    Int      @default(0)
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  categoria WorkflowCategoria @relation(fields: [categoria_id], references: [id], onDelete: Cascade)

  @@index([categoria_id])
  @@map("workflow_categoria_regras")
}

model WorkflowInstanciaSetor {
  id                 String    @id @default(cuid())
  workflow_instancia_id String
  setor_id           String
  item_os_id         String?   // Opcional - pode ser por OS ou por item específico
  status             String    @default("PENDENTE") // PENDENTE, EM_ANDAMENTO, CONCLUIDA, PAUSADA, CANCELADA
  ordem              Int       @default(0)
  data_inicio        DateTime?
  data_conclusao     DateTime?
  operador_id        String?
  tempo_estimado     Int?      // em minutos
  tempo_real         Int?      // em minutos
  observacoes        String?   @db.Text
  criado_em          DateTime  @default(now())
  atualizado_em      DateTime  @updatedAt

  // Relacionamentos
  workflow_instancia WorkflowInstancia @relation(fields: [workflow_instancia_id], references: [id], onDelete: Cascade)
  setor              SetorProdutivo @relation(fields: [setor_id], references: [id])
  item_os            ItemOS? @relation(fields: [item_os_id], references: [id])
  operador           usuario? @relation(fields: [operador_id], references: [id])

  @@index([workflow_instancia_id])
  @@index([setor_id])
  @@index([item_os_id])
  @@index([status])
  @@index([operador_id])
  @@map("workflow_instancia_setor")
}

// ==========================================
// MÓDULO ARTE & APROVAÇÃO
// ==========================================

model ArteVersao {
  id                String   @id @default(cuid())
  os_id             String
  servico_id        String?  // Referência ao serviço específico
  versao            String   // v1, v2, v3, etc.
  status            ArteStatus
  autor_id          String
  descricao         String?
  observacoes       String?
  data_criacao      DateTime @default(now())
  data_aprovacao    DateTime?
  aprovado_por      String?
  aprovado_por_cliente Boolean @default(false)
  liberado_para_pcp    Boolean @default(false) // Liberação final do designer após aprovação do cliente
  liberado_em          DateTime? // Data em que o designer liberou para PCP
  liberado_por         String? // ID do designer que liberou
  loja_id           String   // Multi-tenant
  
  // Soft Delete
  deletado          Boolean  @default(false)
  data_exclusao     DateTime?
  excluido_por      String?
  
  // Relacionamentos
  os                OrdemServico @relation(fields: [os_id], references: [id], onDelete: Cascade)
  autor             usuario @relation("ArteAutor", fields: [autor_id], references: [id])
  aprovador         usuario? @relation("ArteAprovador", fields: [aprovado_por], references: [id])
  liberador         usuario? @relation("ArteLiberador", fields: [liberado_por], references: [id])
  excluidor         usuario? @relation("ArteExcluidor", fields: [excluido_por], references: [id])
  arquivos          ArteArquivo[]
  comentarios       ArteComentario[]
  links_aprovacao   ArteLinkAprovacao[]
  mensagens         ArteMensagem[]
  
  @@map("arte_versoes")
  @@index([os_id, loja_id])
  @@index([status, loja_id])
  @@index([autor_id, loja_id])
  @@index([deletado, loja_id])
}

model ArteArquivo {
  id                String   @id @default(cuid())
  versao_id         String
  nome_arquivo      String
  nome_original     String
  tipo_arquivo      String   // pdf, jpg, png, ai, etc.
  tamanho           BigInt
  url_arquivo       String
  url_thumbnail     String?  // Para preview
  storage_provider  String   // google_drive, aws_s3, local
  storage_path      String
  data_upload       DateTime @default(now())
  loja_id           String   // Multi-tenant
  
  // Relacionamentos
  versao            ArteVersao @relation(fields: [versao_id], references: [id], onDelete: Cascade)
  
  @@map("arte_arquivos")
  @@index([versao_id, loja_id])
  @@index([tipo_arquivo, loja_id])
}

model ArteComentario {
  id                String   @id @default(cuid())
  versao_id         String
  usuario_id        String
  comentario        String   @db.LongText
  tipo              ComentarioTipo @default(INTERNO)
  data_comentario   DateTime @default(now())
  loja_id           String   // Multi-tenant
  
  // Relacionamentos
  versao            ArteVersao @relation(fields: [versao_id], references: [id], onDelete: Cascade)
  usuario           usuario @relation(fields: [usuario_id], references: [id])
  
  @@map("arte_comentarios")
  @@index([versao_id, loja_id])
  @@index([usuario_id, loja_id])
}

model ArteLinkAprovacao {
  id                String   @id @default(cuid())
  versao_id         String
  token_publico     String   @unique
  expira_em         DateTime
  aprovado          Boolean  @default(false)
  data_aprovacao    DateTime?
  ip_aprovacao      String?
  user_agent        String?
  comentario_cliente String? @db.LongText
  ativo             Boolean  @default(true)
  loja_id           String   // Multi-tenant
  
  // Relacionamentos
  versao            ArteVersao @relation(fields: [versao_id], references: [id], onDelete: Cascade)
  
  @@map("arte_links_aprovacao")
  @@index([token_publico])
  @@index([loja_id])
  @@index([expira_em])
}

model ArteMensagem {
  id                String   @id @default(cuid())
  os_id             String
  produto_id        String   // ID do produto específico
  versao_id         String?  // ID da versão (opcional)
  mensagem          String   @db.LongText
  autor_tipo        AutorTipo
  autor_nome        String
  autor_email       String?
  lida              Boolean  @default(false)
  data_leitura      DateTime?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  loja_id           String   // Multi-tenant
  
  // Relacionamentos
  os                OrdemServico @relation(fields: [os_id], references: [id], onDelete: Cascade)
  versao            ArteVersao? @relation(fields: [versao_id], references: [id], onDelete: SetNull)
  
  @@map("arte_mensagens")
  @@index([os_id, produto_id, loja_id])
  @@index([autor_tipo, loja_id])
  @@index([lida, loja_id])
  @@index([created_at, loja_id])
}

enum ArteStatus {
  RASCUNHO
  ENVIADA_CLIENTE
  APROVADA
  REVISAO_SOLICITADA
  BLOQUEADA
  ENVIADA_PCP
}

enum ComentarioTipo {
  INTERNO
  CLIENTE
  SISTEMA
}

enum AutorTipo {
  CLIENTE
  EQUIPE
}
