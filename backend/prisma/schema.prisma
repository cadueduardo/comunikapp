// ===== MÓDULO OS (ORDENS DE SERVIÇO) =====

model OrdemServico {
  id             String    @id @default(cuid())
  numero         String // Autonumeração sequencial
  loja_id        String
  cliente_id     String
  orcamento_id   String? // Opcional - vínculo com orçamento aprovado
  data_abertura  DateTime  @default(now())
  data_prazo     DateTime?
  status         String    @default("FILA")
  responsavel_id String?
  observacoes    String?   @db.Text
  criado_em      DateTime  @default(now())
  atualizado_em  DateTime  @updatedAt

  // Campos específicos do produto/serviço
  nome_servico         String
  descricao            String? @db.Text
  quantidade           Decimal @db.Decimal(10, 2)
  parametros_tecnicos  String? @db.LongText // JSON com medidas, cores, etc
  insumos_calculados   String? @db.LongText // JSON dos insumos necessários
  materiais_disponivel Boolean @default(false)

  // Campos de aprovação técnica (checkpoint pre-produção)
  aprovacao_tecnica_status String?   @default("PENDENTE") // PENDENTE, APROVADA, REJEITADA
  aprovacao_tecnica_por    String? // usuario_id do aprovador
  aprovacao_tecnica_em     DateTime? // data da aprovação
  aprovacao_tecnica_obs    String?   @db.Text // observações da aprovação

  // Campos de agendamento de instalação
  data_instalacao_agendada DateTime? // data agendada para instalação (sincronizada dos lotes — UX-02)
  status_instalacao_os     StatusInstalacaoOs? // rollup operacional DEC-04
  observacoes_instalacao   String?             @db.Text // observações para coordenação de instalação externa

  // Campos para diferenciação OS Direta vs Interna
  tipo_os    String  @default("COMERCIAL") // COMERCIAL, INTERNA
  origem_os  String? // ORCAMENTO, DIRETA, INTERNA
  prioridade String  @default("NORMAL") // URGENTE, ALTA, NORMAL, BAIXA

  // Campos específicos para OS Interna
  departamento_solicitante String? // Departamento que solicitou a OS interna
  centro_custo             String? // Centro de custo para OS interna
  projeto_interno          String? // Projeto interno relacionado
  aprovacao_gerencial      String?   @default("PENDENTE") // PENDENTE, APROVADA, REJEITADA
  aprovacao_gerencial_por  String? // usuario_id do aprovador gerencial
  aprovacao_gerencial_em   DateTime? // data da aprovação gerencial
  aprovacao_gerencial_obs  String?   @db.Text // observações da aprovação gerencial

  // Campos específicos para OS Comercial
  valor_orcado         Decimal?  @db.Decimal(12, 2) // Valor do orçamento aprovado
  valor_realizado      Decimal?  @db.Decimal(12, 2) // Valor real gasto na produção
  margem_lucro_real    Decimal?  @db.Decimal(5, 2) // Margem de lucro real obtida
  data_entrega_cliente DateTime? // Data real de entrega ao cliente
  satisfacao_cliente   Int? // Nota de satisfação do cliente (1-5)
  observacoes_cliente  String?   @db.Text // Observações do cliente sobre o serviço

  // Campos de controle e auditoria
  criado_por         String? // usuario_id que criou a OS
  modificado_por     String? // usuario_id que fez a última modificação
  motivo_modificacao String? @db.Text // Motivo da última modificação
  versao             Int     @default(1) // Controle de versão da OS

  // Módulo Expedição — badge de retrabalho após devolução da expedição para o PCP
  retrabalho Boolean @default(false)

  // Soft inativação (substitui delete físico — OS de teste / limpeza operacional)
  ativo                     Boolean   @default(true)
  inativado_em              DateTime?
  inativado_por             String?
  motivo_inativacao         String?   @db.Text
  status_antes_inativacao   String?
  snapshot_antes_inativacao String?   @db.LongText // JSON para reativação

  // Split financeiro — OS Aditiva (Fase 5 evolutiva)
  os_pai_id               String?
  tipo_vinculo_os         String? @db.VarChar(24) // PRINCIPAL | ADITIVA_INSTALACAO
  pular_pcp               Boolean @default(false)
  pular_expedicao         Boolean @default(false)
  pular_validacao_estoque Boolean @default(false)

  // Relacionamentos
  loja      loja       @relation(fields: [loja_id], references: [id])
  cliente   cliente    @relation(fields: [cliente_id], references: [id])
  orcamento orcamento? @relation(fields: [orcamento_id], references: [id])

  os_pai    OrdemServico?  @relation("OsFilhas", fields: [os_pai_id], references: [id], onDelete: SetNull)
  os_filhas OrdemServico[] @relation("OsFilhas")

  // Relacionamentos internos do módulo
  itens                        ItemOS[]
  movimentacoes                MovimentacaoOS[]
  checklists                   ChecklistOS[]
  workflow_instancia           WorkflowInstancia?
  apontamentos                 Apontamento[]
  logs                         OrdemServicoLog[]
  execucoes_regras             ExecucaoRegra[]
  expedicoes_logistica         ExpedicaoLogistica[]
  ocorrencias_instalacao       OcorrenciaInstalacao[]       @relation("OcorrenciasOsPai")
  ocorrencias_faturadas        OcorrenciaInstalacao[]       @relation("OcorrenciasFaturadas")
  relatorio_tecnico_instalacao RelatorioTecnicoInstalacao?
  orcamentos_aditivos_pai      OrcamentoAditivoInstalacao[] @relation("OrcamentosAditivosPai")
  orcamento_aditivo_meta       OrcamentoAditivoInstalacao?  @relation("OrcamentoAditivoOsFilha")

  // Relacionamentos Arte & Aprovação
  artes_versoes   ArteVersao[]
  artes_mensagens ArteMensagem[]

  // Relacionamentos Compras (MVP Fase 1)
  apropriacoes_compra PedidoCompraItemApropriacao[]

  @@unique([loja_id, numero])
  @@index([loja_id, status])
  @@index([loja_id, ativo])
  @@index([loja_id, retrabalho])
  @@index([cliente_id])
  @@index([orcamento_id])
  @@index([responsavel_id])
  @@index([data_abertura])
  @@index([aprovacao_tecnica_status])
  @@index([aprovacao_tecnica_por])
  @@index([data_instalacao_agendada])
  @@index([tipo_os])
  @@index([origem_os])
  @@index([prioridade])
  @@index([departamento_solicitante])
  @@index([centro_custo])
  @@index([aprovacao_gerencial])
  @@index([aprovacao_gerencial_por])
  @@index([data_entrega_cliente])
  @@index([criado_por])
  @@index([modificado_por])
  @@index([versao])
  @@index([loja_id, os_pai_id])
  @@index([loja_id, tipo_vinculo_os])
  @@map("ordens_servico")
}

model ItemOS {
  id                   String   @id @default(cuid())
  os_id                String
  produto_servico      String
  quantidade           Decimal  @db.Decimal(10, 2)
  parametros_tecnicos  String?  @db.LongText // JSON
  insumos_necessarios  String?  @db.LongText // JSON calculado
  materiais_disponivel Boolean  @default(false)
  observacoes          String?  @db.Text
  sobra_acao           String?  @db.VarChar(32)
  sobra_observacao     String?  @db.Text
  sobra_registrada_id  String?
  criado_em            DateTime @default(now())

  // Geometria herdada do ProdutoOrcamento para PCP/produção
  largura                     Decimal? @db.Decimal(10, 2)
  altura                      Decimal? @db.Decimal(10, 2)
  // Fase 11: profundidade opcional para produtos 3D (totens, letras caixa, displays).
  // Quando preenchida, sera usada por insumos com unidade_uso='M3' (volume) ou 'M2_LATERAL' (caixa aberta 4 laterais).
  profundidade                Decimal? @db.Decimal(10, 2)
  area                        Decimal? @db.Decimal(10, 2)
  perimetro                   Decimal? @db.Decimal(10, 2)
  unidade_medida              String?  @db.VarChar(16)
  unidade_geometria           String?  @db.VarChar(4)
  geometria_origem            String?  @db.VarChar(16)
  arquivo_geometria_url       String?  @db.VarChar(512)
  arquivo_geometria_metadados String?  @db.LongText

  // PRAZOS DO PRODUTO
  data_inicio_producao DateTime? // Quando deve iniciar produção
  data_prazo_produto   DateTime? // Prazo específico deste produto

  // LIBERAÇÃO PCP
  status_liberacao_pcp String?   @default("PENDENTE") // PENDENTE, BLOQUEADO_AGUARDANDO_SINAL, LIBERADO, EM_PRODUCAO, CONCLUIDO
  liberado_pcp_por     String? // usuario_id
  liberado_pcp_em      DateTime? // Data de liberação

  // PRIORIDADE E ORDEM
  prioridade_produto String? @default("NORMAL") // URGENTE, ALTA, NORMAL, BAIXA
  ordem_producao     Int? // Ordem de produção (1, 2, 3...)

  // Módulo Arte & Aprovação (propagado do orçamento)
  responsabilidade_arte  String    @default("NAO_APLICAVEL") @db.VarChar(32)
  politica_cobranca_arte String    @default("NAO_APLICAVEL") @db.VarChar(32)
  finalidade_anexo       String?   @db.VarChar(32)
  complexidade_arte      String?   @db.VarChar(16)
  status_arte            String    @default("NAO_APLICA") @db.VarChar(32)
  designer_atribuido_id  String?
  arte_fila_desde        DateTime?
  arte_assumido_em       DateTime?
  data_prazo_arte        DateTime?
  arte_drive_folder_id   String?   @db.VarChar(191)

  // Módulo Catálogo — personalização de prateleira (estampa / imprint / VDP)
  modo_fulfillment       ModoFulfillmentItem? @default(PICK)
  personalizacao_modo    ModoPersonalizacao?
  estampa_id             String?
  valores_personalizacao Json? // polimórfico: Record<string,string> | Record<string,string>[]
  grade_distribuicao     Json? // [{ atributos, quantidade }]
  arte_producao_url      String?              @db.Text // PDF print-ready (catálogo VDP)
  fornecedor_id          String?

  os                  OrdemServico             @relation(fields: [os_id], references: [id], onDelete: Cascade)
  estampa             Estampa?                 @relation(fields: [estampa_id], references: [id], onDelete: SetNull)
  instancias_setor    WorkflowInstanciaSetor[]
  designer_atribuido  usuario?                 @relation("ItemOSDesigner", fields: [designer_atribuido_id], references: [id], onDelete: SetNull)
  lotes_instalacao    ItemOSInstalacao[]
  fornecedor          fornecedor?              @relation(fields: [fornecedor_id], references: [id], onDelete: SetNull, map: "ItemOS_fornecedor_id_fkey")
  ordem_terceirizacao OrdemTerceirizacao?
  solicitacao_compra_itens SolicitacaoCompraItem[]
  apropriacoes_compra      PedidoCompraItemApropriacao[] @relation("PedidoCompraApropriacaoItemOS")

  @@index([os_id])
  @@index([status_liberacao_pcp])
  @@index([data_inicio_producao])
  @@index([status_arte])
  @@index([responsabilidade_arte])
  @@index([designer_atribuido_id])
  @@index([estampa_id])
  @@index([modo_fulfillment])
  @@index([personalizacao_modo])
  @@index([fornecedor_id])
  @@map("itens_os")
}

model OrdemTerceirizacao {
  id                String                   @id @default(cuid())
  loja_id           String
  item_os_id        String                   @unique
  fornecedor_id     String
  status            StatusOrdemTerceirizacao @default(A_COTAR)
  custo_unitario    Decimal?                 @db.Decimal(12, 2)
  custo_setup       Decimal?                 @db.Decimal(12, 2)
  custo_frete       Decimal?                 @db.Decimal(12, 2)
  custo_total       Decimal?                 @db.Decimal(12, 2)
  prazo_dias        Int?
  data_prevista     DateTime?
  observacoes       String?                  @db.Text
  pedido_enviado_em DateTime?
  iniciado_em       DateTime?
  concluido_em      DateTime?
  recebido_em       DateTime?
  entregue_em       DateTime?
  criado_em         DateTime                 @default(now())
  atualizado_em     DateTime                 @updatedAt

  loja       loja       @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  item_os    ItemOS     @relation(fields: [item_os_id], references: [id], onDelete: Cascade)
  fornecedor fornecedor @relation(fields: [fornecedor_id], references: [id], onDelete: Restrict)
  solicitacao_compra_itens SolicitacaoCompraItem[]
  pedido_compra_itens      PedidoCompraItem[]      @relation("PedidoCompraItemOrdemTerceirizacao")

  @@index([loja_id, status])
  @@index([fornecedor_id, status])
  @@index([data_prevista])
  @@map("ordens_terceirizacao")
}

model WorkflowOS {
  id            String   @id @default(cuid())
  loja_id       String
  nome          String
  descricao     String?  @db.Text
  etapas        String   @db.LongText // JSON das etapas configuráveis
  ativo         Boolean  @default(true)
  sequencial    Boolean  @default(true) // true = sequencial, false = paralelo
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  loja             loja                     @relation(fields: [loja_id], references: [id])
  instancias       WorkflowInstancia[]
  workflow_setores WorkflowSetor[]
  categorias       WorkflowCategoria[]      @relation("WorkflowCategoriaWorkflow")
  instancias_setor WorkflowInstanciaSetor[]

  @@unique([loja_id, nome])
  @@index([loja_id, ativo])
  @@map("workflows_os")
}

model MovimentacaoOS {
  id                String   @id @default(cuid())
  os_id             String
  etapa_anterior    String?
  etapa_atual       String
  usuario_id        String
  data_movimentacao DateTime @default(now())
  observacoes       String?  @db.Text
  anexos            String?  @db.LongText // JSON de anexos
  ip_origem         String?
  user_agent        String?

  os OrdemServico @relation(fields: [os_id], references: [id], onDelete: Cascade)

  @@index([os_id])
  @@index([data_movimentacao])
  @@index([usuario_id])
  @@map("movimentacoes_os")
}

model ChecklistOS {
  id             String    @id @default(cuid())
  os_id          String
  etapa          String
  item_checklist String
  concluido      Boolean   @default(false)
  usuario_id     String?
  data_conclusao DateTime?
  observacoes    String?   @db.Text
  obrigatório   Boolean   @default(true)
  ordem          Int       @default(0)

  os OrdemServico @relation(fields: [os_id], references: [id], onDelete: Cascade)

  @@index([os_id, etapa])
  @@index([concluido])
  @@map("checklists_os")
}

// ===== ENTIDADES DE WORKFLOW PARA PCP =====

model WorkflowInstancia {
  id            String    @id @default(cuid())
  os_id         String    @unique
  workflow_id   String
  status        String    @default("ATIVO") // ATIVO, PAUSADO, CONCLUIDO, CANCELADO
  etapa_atual   String?
  data_inicio   DateTime  @default(now())
  data_fim      DateTime?
  criado_em     DateTime  @default(now())
  atualizado_em DateTime  @updatedAt

  // Relacionamentos
  os               OrdemServico             @relation(fields: [os_id], references: [id], onDelete: Cascade)
  workflow         WorkflowOS               @relation(fields: [workflow_id], references: [id])
  etapas           EtapaInstancia[]
  instancias_setor WorkflowInstanciaSetor[]

  @@index([workflow_id])
  @@index([status])
  @@index([etapa_atual])
  @@index([data_inicio])
  @@map("workflow_instancia")
}

model EtapaInstancia {
  id                    String    @id @default(cuid())
  workflow_instancia_id String
  etapa_nome            String
  ordem                 Int
  status                String    @default("PENDENTE") // PENDENTE, EM_ANDAMENTO, CONCLUIDA, PAUSADA, CANCELADA
  data_inicio           DateTime?
  data_fim              DateTime?
  responsavel_id        String?
  tempo_estimado        Int? // em minutos
  tempo_real            Int? // em minutos
  observacoes           String?   @db.Text
  criado_em             DateTime  @default(now())
  atualizado_em         DateTime  @updatedAt

  // Relacionamentos
  workflow_instancia WorkflowInstancia    @relation(fields: [workflow_instancia_id], references: [id], onDelete: Cascade)
  checklists         ChecklistInstancia[]
  apontamentos       Apontamento[]

  @@index([workflow_instancia_id])
  @@index([etapa_nome])
  @@index([status])
  @@index([ordem])
  @@index([responsavel_id])
  @@map("etapa_instancia")
}

model ChecklistInstancia {
  id                 String    @id @default(cuid())
  etapa_instancia_id String
  item_descricao     String    @db.VarChar(500)
  obrigatorio        Boolean   @default(true)
  concluido          Boolean   @default(false)
  concluido_por      String?
  data_conclusao     DateTime?
  observacoes        String?   @db.Text
  ordem              Int       @default(0)
  criado_em          DateTime  @default(now())
  atualizado_em      DateTime  @updatedAt

  // Relacionamentos
  etapa_instancia EtapaInstancia @relation(fields: [etapa_instancia_id], references: [id], onDelete: Cascade)

  @@index([etapa_instancia_id])
  @@index([concluido])
  @@index([ordem])
  @@map("checklist_instancia")
}

model Apontamento {
  id                   String   @id @default(cuid())
  os_id                String
  etapa_instancia_id   String?
  tipo                 String // INICIO, PAUSA, RETOMADA, CONCLUSAO, REFUGO
  data_apontamento     DateTime @default(now())
  usuario_id           String
  observacoes          String?  @db.Text
  quantidade_produzida Decimal? @db.Decimal(10, 3)
  quantidade_refugo    Decimal? @db.Decimal(10, 3)
  tempo_gasto          Int? // em minutos
  ip_origem            String?
  user_agent           String?  @db.VarChar(500)
  criado_em            DateTime @default(now())

  // Relacionamentos
  os              OrdemServico    @relation(fields: [os_id], references: [id], onDelete: Cascade)
  etapa_instancia EtapaInstancia? @relation(fields: [etapa_instancia_id], references: [id])

  @@index([os_id])
  @@index([etapa_instancia_id])
  @@index([tipo])
  @@index([data_apontamento])
  @@index([usuario_id])
  @@map("apontamento")
}

