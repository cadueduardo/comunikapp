  nome               String
  descricao          String?  @db.Text
  ativo              Boolean  @default(true)
  exige_endereco     Boolean  @default(false)
  exige_valor        Boolean  @default(false)
  valor_padrao       Decimal? @db.Decimal(12, 2)
  custo_padrao       Decimal? @db.Decimal(12, 2)
  prazo_padrao_dias  Int?
  permite_retirada   Boolean  @default(false)
  observacoes_padrao String?  @db.Text
