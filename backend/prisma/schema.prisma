generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Insumo {
  id                      String                 @id @default(cuid())
  loja_id                 String
  nome                    String
  descricao_tecnica       String?
  descricao               String? // Campo para V2
  codigo                  String? // Campo para V2
  custo_unitario          Decimal                @db.Decimal(10, 2)
  estoque_minimo          Int?
  estoque_atual           Decimal?               @db.Decimal(10, 3) // Campo para V2
  codigo_interno          String?
  observacoes             String?
  categoriaId             String
  fornecedorId            String
  atualizado_em           DateTime               @updatedAt
  criado_em               DateTime               @default(now())
  ativo                   Boolean                @default(true)
  fator_conversao         Decimal                @db.Decimal(10, 4)
  quantidade_compra       Decimal                @db.Decimal(10, 3)
  unidade_uso             String
  altura                  Decimal?               @db.Decimal(10, 2)
  gramatura               Decimal?               @db.Decimal(10, 1)
  largura                 Decimal?               @db.Decimal(10, 2)
  unidade_compra          String
  tipo_calculo            String?
  unidade_dimensao        String?
  tipoMaterialId          String?
  logica_consumo          LogicaConsumoInsumo    @default(area)
  parametros_consumo      String?                @db.LongText
  formato_material        String?                @db.VarChar(32)
  largura_comercial       Decimal?               @db.Decimal(10, 3)
  altura_comercial        Decimal?               @db.Decimal(10, 3)
  comprimento_comercial   Decimal?               @db.Decimal(10, 3)
  area_comercial          Decimal?               @db.Decimal(10, 4)
  perda_padrao_percent    Decimal?               @db.Decimal(5, 2)
  permite_simulacao_chapa Boolean                @default(false)
  controla_estoque        Boolean                @default(false)
  permite_registrar_sobra Boolean                @default(false)
  retalho_min_largura     Decimal?               @db.Decimal(10, 3)
  retalho_min_altura      Decimal?               @db.Decimal(10, 3)
  retalho_min_area        Decimal?               @db.Decimal(10, 4)
  metodo_cobranca_padrao  String?                @db.VarChar(32)
  historico_precos        HistoricoPrecoInsumo[]
  categoria               Categoria              @relation(fields: [categoriaId], references: [id])
  fornecedor              fornecedor             @relation(fields: [fornecedorId], references: [id])
  loja                    loja                   @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  tipoMaterial            tipomaterial?          @relation(fields: [tipoMaterialId], references: [id])
  itens_template          ItemTemplateProduto[]
  itemorcamento           itemorcamento[]
  itemInsumo              ItemInsumo[]
  estoque                 estoque[]
  fornecedores_associados InsumoFornecedor[]
  solicitacao_compra_itens SolicitacaoCompraItem[]
  pedido_compra_itens      PedidoCompraItem[]

  @@unique([loja_id, nome])
  @@index([categoriaId], map: "insumos_categoriaId_fkey")
  @@index([fornecedorId], map: "insumos_fornecedorId_fkey")
  @@index([tipoMaterialId], map: "insumos_tipoMaterialId_fkey")
  @@map("insumos")
}

model Categoria {
  id      String   @id @default(cuid())
  loja_id String
  nome    String
  loja    loja     @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  insumos Insumo[]

  @@unique([loja_id, nome])
  @@map("categorias")
}

model OrcamentoLog {
  id           String    @id @default(cuid())
  orcamento_id String
  tipo_acao    String
  descricao    String    @db.Text
  dados_extras String?   @db.LongText
  ip_origem    String?
  user_agent   String?
  criado_em    DateTime  @default(now())
  orcamento    orcamento @relation(fields: [orcamento_id], references: [id], onDelete: Cascade)

  @@index([orcamento_id])
  @@index([tipo_acao])
  @@index([criado_em])
  @@map("orcamento_logs")
}

model HistoricoPrecoInsumo {
  id             String   @id @default(cuid())
  insumo_id      String
  custo_anterior Decimal  @db.Decimal(10, 2)
  custo_novo     Decimal  @db.Decimal(10, 2)
  data_alteracao DateTime @default(now())
  motivo         String?  @db.Text
  alterado_por   String?
  insumo         Insumo   @relation(fields: [insumo_id], references: [id], onDelete: Cascade)

  @@index([insumo_id], map: "historico_preco_insumos_insumo_id_fkey")
  @@map("historico_preco_insumos")
}

model OrcamentoHistorico {
  id               String    @id @default(cuid())
  orcamento_id     String
  versao           Int
  dados_anteriores String    @db.LongText
  dados_novos      String    @db.LongText
  alteracoes       String?   @db.LongText
  motivo           String?   @db.Text
  alterado_por     String?
  criado_em        DateTime  @default(now())
  orcamento        orcamento @relation(fields: [orcamento_id], references: [id], onDelete: Cascade)

  @@index([orcamento_id])
  @@index([versao])
  @@map("orcamento_historico")
}

// ============================================================================
// Fase 6 - Financeiro minimo: Cobranca, parcelas, recebimentos e auditoria.
// Decisao Fase 0: status oficiais sao SEM_COBRANCA | PREVISTA_ENTRADA |
// PREVISTA_SALDO | PARCIAL_PAGO | LIQUIDADO | VENCIDO | CANCELADA.
// Para simplificar e suportar PARCELADO (N parcelas), o status oficial fica em
// `cobranca.status` como rollup das parcelas, e cada parcela mantem seu proprio
// status individual em `cobranca_parcela.status`.
// ============================================================================

model Cobranca {
  id           String  @id @default(cuid())
  loja_id      String
  orcamento_id String  @unique // 1:1 com orcamento
  cliente_id   String?

  // Tipo da condicao de pagamento. Espelha `orcamento.condicao_pagamento_tipo`.
  tipo                String    @db.VarChar(32)
  // Descricao livre exibivel ao cliente (auto-gerada para A_VISTA/ENTRADA_SALDO/FATURADO_*;
  // editavel manualmente para PARCELADO/PERSONALIZADO).
  descricao           String?   @db.VarChar(255)
  // Status rollup. Atualizado por trigger de servico apos cada movimento.
  // Valores: PREVISTA | PARCIAL_PAGO | LIQUIDADO | VENCIDO | CANCELADA
  status              String    @default("PREVISTA") @db.VarChar(24)
  valor_total         Decimal   @db.Decimal(12, 2)
  valor_recebido      Decimal   @default(0) @db.Decimal(12, 2)
  valor_saldo         Decimal   @db.Decimal(12, 2) // calculado: valor_total - valor_recebido
  data_aprovacao      DateTime // data em que a cobranca foi criada (= orcamento.data_aprovacao)
  liquidado_em        DateTime?
  cancelado_em        DateTime?
  cancelado_por       String?
  motivo_cancelamento String?   @db.Text

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt
  criado_por    String? // usuario_id que disparou a aprovacao

  loja         loja                  @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  orcamento    orcamento             @relation(fields: [orcamento_id], references: [id], onDelete: Cascade)
  cliente      cliente?              @relation(fields: [cliente_id], references: [id])
  parcelas     CobrancaParcela[]
  recebimentos CobrancaRecebimento[]
  logs         CobrancaLog[]

  @@index([loja_id])
  @@index([cliente_id])
  @@index([status])
  @@index([data_aprovacao])
  @@index([loja_id, status])
  @@map("cobrancas")
}

model CobrancaParcela {
  id          String @id @default(cuid())
  cobranca_id String

  // Ordem da parcela (1 = entrada, 2 = primeira parcela do saldo, etc).
  ordem Int
  // Tipo da parcela: ENTRADA | SALDO | PARCELA (numerada).
  tipo  String @db.VarChar(16)

  valor_previsto  Decimal  @db.Decimal(12, 2)
  valor_recebido  Decimal  @default(0) @db.Decimal(12, 2)
  data_vencimento DateTime

  // Status individual: PREVISTO | PARCIAL_PAGO | LIQUIDADO | VENCIDO | CANCELADA | AGUARDANDO_RELATORIO_TECNICO | A_FATURAR.
  status       String    @default("PREVISTO") @db.VarChar(32)
  liquidado_em DateTime?

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  cobranca     Cobranca              @relation(fields: [cobranca_id], references: [id], onDelete: Cascade)
  recebimentos CobrancaRecebimento[]

  @@index([cobranca_id])
  @@index([status])
  @@index([data_vencimento])
  @@map("cobranca_parcelas")
}

model CobrancaRecebimento {
  id          String  @id @default(cuid())
  cobranca_id String
  parcela_id  String? // nullable apenas para historico anterior; novos sempre tem parcela.

  valor            Decimal  @db.Decimal(12, 2)
  data_recebimento DateTime
  // Metodos suportados: PIX | TRANSFERENCIA | BOLETO | DINHEIRO | CARTAO | OUTRO.
  metodo           String   @db.VarChar(16)
  observacoes      String?  @db.Text

  // Flag para indicar recebimento criado via 'forcar liquidacao' (acao sensivel).
  forcado Boolean @default(false)

  usuario_id String? // quem registrou
  criado_em  DateTime @default(now())

  cobranca Cobranca         @relation(fields: [cobranca_id], references: [id], onDelete: Cascade)
  parcela  CobrancaParcela? @relation(fields: [parcela_id], references: [id])
  usuario  usuario?         @relation(fields: [usuario_id], references: [id])

  @@index([cobranca_id])
  @@index([parcela_id])
  @@index([data_recebimento])
  @@index([usuario_id])
  @@map("cobranca_recebimentos")
}

model CobrancaLog {
  id          String @id @default(cuid())
  cobranca_id String

  // Acoes registradas: COBRANCA_CRIADA | RECEBIMENTO_REGISTRADO | PARCIAL_PAGO |
  // LIQUIDADA | MARCADA_VENCIDA | CANCELADA | FORCADA_LIQUIDACAO | EDITADA.
  tipo_acao String @db.VarChar(32)
  descricao String @db.Text

  status_anterior   String?  @db.VarChar(24)
  status_novo       String?  @db.VarChar(24)
  valor_movimentado Decimal? @db.Decimal(12, 2)

  usuario_id   String?
  ip_origem    String? @db.VarChar(45)
  user_agent   String? @db.VarChar(255)
  dados_extras String? @db.LongText

  criado_em DateTime @default(now())

  cobranca Cobranca @relation(fields: [cobranca_id], references: [id], onDelete: Cascade)
  usuario  usuario? @relation(fields: [usuario_id], references: [id])

  @@index([cobranca_id])
  @@index([tipo_acao])
  @@index([criado_em])
  @@index([usuario_id])
  @@map("cobranca_logs")
}

model OrdemServicoLog {
  id           String   @id @default(cuid())
  os_id        String
  tipo_acao    String
  descricao    String   @db.Text
  dados_extras String?  @db.LongText
  ip_origem    String?
  user_agent   String?
  criado_em    DateTime @default(now())
  usuario_id   String?

  // Relacionamentos
  os      OrdemServico @relation(fields: [os_id], references: [id], onDelete: Cascade)
  usuario usuario?     @relation(fields: [usuario_id], references: [id])

  @@index([os_id])
  @@index([tipo_acao])
  @@index([criado_em])
  @@index([usuario_id])
  @@map("ordem_servico_logs")
}

model RegraValidacao {
  id            String   @id @default(cuid())
  loja_id       String
  nome          String
  descricao     String?  @db.Text
  categoria     String
  tipo          String // BLOQUEIO, ALERTA, INFO
  condicoes     String   @db.LongText // JSON com as condições
  acoes         String?  @db.LongText // JSON com as ações
  mensagem      String   @db.Text
  ativo         Boolean  @default(true)
  prioridade    Int      @default(0)
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  loja      loja            @relation(fields: [loja_id], references: [id])
  execucoes ExecucaoRegra[]

  @@index([loja_id])
  @@index([categoria])
  @@index([ativo])
  @@map("regras_validacao")
}

model ExecucaoRegra {
  id             String   @id @default(cuid())
  regra_id       String
  os_id          String?
  orcamento_id   String?
  resultado      String // SUCESSO, ERRO, ALERTA, BLOQUEIO
  mensagem       String?  @db.Text
  dados_execucao String?  @db.LongText // JSON
  tempo_execucao Int? // ms
  criado_em      DateTime @default(now())

  regra     RegraValidacao @relation(fields: [regra_id], references: [id], onDelete: Cascade)
  os        OrdemServico?  @relation(fields: [os_id], references: [id])
  orcamento orcamento?     @relation(fields: [orcamento_id], references: [id])

  @@index([regra_id])
  @@index([os_id])
  @@index([orcamento_id])
  @@index([resultado])
  @@index([criado_em])
  @@map("execucoes_regras")
}

model TemplateProduto {
  id                     String                   @id @default(cuid())
  criado_em              DateTime                 @default(now())
  atualizado_em          DateTime                 @updatedAt
  nome                   String
  categoria              String
  descricao              String?                  @db.Text
  nome_servico           String
  descricao_produto      String?                  @db.Text
  horas_producao         Decimal                  @db.Decimal(10, 2)
  largura_produto        Decimal?                 @db.Decimal(10, 2)
  altura_produto         Decimal?                 @db.Decimal(10, 2)
  profundidade_produto   Decimal?                 @db.Decimal(10, 2)
  area_produto           Decimal?                 @db.Decimal(10, 2)
  perimetro_produto      Decimal?                 @db.Decimal(10, 2)
  unidade_geometria      String?                  @db.VarChar(4)
  geometria_origem       String?                  @db.VarChar(16)
  arquivo_geometria_url  String?                  @db.VarChar(512)
  unidade_medida_produto String?
  quantidade_padrao      Decimal?                 @db.Decimal(10, 2)
  ativo                  Boolean                  @default(true)
  loja_id                String
  valor_calculado        Decimal?                 @db.Decimal(10, 2)
  itens_orcamento_json   String?                  @db.Text
  funcoes                FuncaoTemplateProduto[]
  itens                  ItemTemplateProduto[]
  maquinas               MaquinaTemplateProduto[]
  servicos               ServicoTemplateProduto[]
  loja                   loja                     @relation(fields: [loja_id], references: [id], onDelete: Cascade)

  @@unique([loja_id, nome])
  @@index([loja_id])
  @@index([loja_id, categoria])
  @@map("template_produtos")
}

model ItemTemplateProduto {
  id                      String          @id @default(cuid())
  template_id             String
  insumo_id               String
  quantidade              Decimal         @db.Decimal(10, 3)
  custo_unitario          Decimal         @db.Decimal(10, 2)
  custo_total             Decimal         @db.Decimal(10, 2)
  usa_medida_propria      Boolean         @default(false)
  largura_material        Decimal?        @db.Decimal(10, 2)
  altura_material         Decimal?        @db.Decimal(10, 2)
  profundidade_material   Decimal?        @db.Decimal(10, 2)
  unidade_medida_material String?         @db.VarChar(4)
  insumo                  Insumo          @relation(fields: [insumo_id], references: [id])
  template                TemplateProduto @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@index([template_id])
  @@index([insumo_id])
  @@map("item_template_produtos")
}

model MaquinaTemplateProduto {
  id               String          @id @default(cuid())
  template_id      String
  maquina_id       String
  horas_utilizadas Decimal         @db.Decimal(10, 2)
  custo_total      Decimal         @db.Decimal(10, 2)
  maquina          maquina         @relation(fields: [maquina_id], references: [id])
  template         TemplateProduto @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@index([template_id])
  @@index([maquina_id])
  @@map("maquina_template_produtos")
}

model FuncaoTemplateProduto {
  id                String          @id @default(cuid())
  template_id       String
  funcao_id         String
  horas_trabalhadas Decimal         @db.Decimal(10, 2)
  custo_total       Decimal         @db.Decimal(10, 2)
  funcao            funcao          @relation(fields: [funcao_id], references: [id])
  template          TemplateProduto @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@index([template_id])
  @@index([funcao_id])
  @@map("funcao_template_produtos")
}

model ServicoTemplateProduto {
  id                String          @id @default(cuid())
  template_id       String
  servico_id        String
  horas_trabalhadas Decimal         @db.Decimal(10, 2)
  custo_total       Decimal         @db.Decimal(10, 2)
  servico           servico_manual  @relation(fields: [servico_id], references: [id])
  template          TemplateProduto @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@index([template_id])
  @@index([servico_id])
  @@map("servico_template_produtos")
}

model cliente {
  id                 String                 @id @default(cuid())
  criado_em          DateTime               @default(now())
  atualizado_em      DateTime               @updatedAt
  nome               String
  tipo_pessoa        cliente_tipo_pessoa
  documento          String
  email              String?
  telefone           String?
  whatsapp           String?
  cep                String?
  endereco           String?
  numero             String?
  complemento        String?
  bairro             String?
  cidade             String?
  estado             String?
  razao_social       String?
  nome_fantasia      String?
  inscricao_estadual String?
  responsavel        String?
  cargo_responsavel  String?
  observacoes        String?                @db.Text
  status_cliente     cliente_status_cliente @default(ATIVO)
  ativo              Boolean                @default(true) // Campo para V2
  origem             String?
  segmento           String?
  loja_id            String
  loja               loja                   @relation(fields: [loja_id], references: [id], onDelete: Cascade, map: "Cliente_loja_id_fkey")
  orcamento          orcamento[]
  ordens_servico     OrdemServico[]
  cobrancas          Cobranca[] // Fase 6

  @@index([loja_id, documento], map: "Cliente_loja_id_documento_idx")
  @@index([loja_id], map: "Cliente_loja_id_idx")
  @@index([loja_id, nome], map: "Cliente_loja_id_nome_idx")
}

model custoindireto {
  id                String              @id @default(cuid())
  criado_em         DateTime            @default(now())
  atualizado_em     DateTime
  nome              String
  valor_mensal      Decimal             @db.Decimal(10, 2)
  categoria         String
  ativo             Boolean             @default(true)
  regra_rateio      String              @default("PROPORCIONAL_TEMPO")
  observacoes       String?             @db.Text
  loja_id           String
  setor_id          String? // null = custo geral; preenchido = custo do setor
  loja              loja                @relation(fields: [loja_id], references: [id], onDelete: Cascade, map: "CustoIndireto_loja_id_fkey")
  setor             SetorProdutivo?     @relation(fields: [setor_id], references: [id], onDelete: SetNull, map: "CustoIndireto_setor_id_fkey")
  itemCustoIndireto ItemCustoIndireto[]

  @@index([loja_id, categoria], map: "CustoIndireto_loja_id_categoria_idx")
  @@index([loja_id], map: "CustoIndireto_loja_id_idx")
  @@index([setor_id], map: "CustoIndireto_setor_id_idx")
}

enum TipoFornecedor {
  INSUMO
  TERCEIRIZADO
  AMBOS
}

enum ModeloCustoTerceirizacao {
  DETALHADO
  PRECO_FECHADO
}

enum StatusOrdemTerceirizacao {
  A_COTAR
  COTADO
  PEDIDO_ENVIADO
  EM_PRODUCAO
  PRONTO
  EM_TRANSITO
  RECEBIDO
  ENTREGUE
  CANCELADO
}

model fornecedor {
  id           String         @id @default(cuid())
  loja_id      String
  nome         String
  razao_social String?
  cnpj_cpf     String?
  tipo         TipoFornecedor @default(INSUMO)
  ativo        Boolean        @default(true)

  // Contatos
  contato_nome String?
  telefone     String?
  whatsapp     String?
  email        String?

  // Endereço
  cep         String?
  endereco    String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?

  // Especialidades (JSON array de tags)
  especialidades Json?

  // Relacionamentos
  loja                           loja                     @relation(fields: [loja_id], references: [id], onDelete: Cascade, map: "Fornecedor_loja_id_fkey")
  insumos                        Insumo[]
  itens_terceirizados            ItemOS[]
  produtos_orcados_terceirizados ProdutoOrcamento[]
  ordens_terceirizacao           OrdemTerceirizacao[]
  insumos_associados             InsumoFornecedor[]
  itens_insumo_previstos         ItemInsumo[]              @relation("ItemInsumoFornecedorPrevisto")
  pedidos_compra                 PedidoCompra[]

  @@unique([loja_id, nome], map: "Fornecedor_loja_id_nome_key")
  @@index([loja_id], map: "Fornecedor_loja_id_idx")
}

model funcao {
  id                   String                  @id @default(cuid())
  criado_em            DateTime                @default(now())
  atualizado_em        DateTime                @updatedAt
  nome                 String
  custo_hora           Decimal                 @db.Decimal(10, 2)
  descricao            String?                 @db.Text
  maquina_id           String?
  loja_id              String
  setor_id             String? // Setor ao qual a função pertence
  ativo                Boolean                 @default(true) // Campo para V2
  tipo_calculo         funcao_tipo_calculo     @default(MANUAL)
  fator_acompanhamento Decimal?                @db.Decimal(10, 3)
  horas_por_m2         Decimal?                @db.Decimal(10, 3)
  horas_por_unidade    Decimal?                @db.Decimal(10, 3)
  eficiencia_percent   Decimal?                @db.Decimal(5, 2)
  setup_min            Decimal?                @db.Decimal(10, 2)
  loja                 loja                    @relation(fields: [loja_id], references: [id], onDelete: Cascade, map: "Funcao_loja_id_fkey")
  maquina              maquina?                @relation(fields: [maquina_id], references: [id], map: "Funcao_maquina_id_fkey")
  setor                SetorProdutivo?         @relation(fields: [setor_id], references: [id], onDelete: SetNull, map: "Funcao_setor_id_fkey")
  funcoes_template     FuncaoTemplateProduto[]
  funcaoorcamento      funcaoorcamento[]
  itemFuncao           ItemFuncao[]

  @@index([loja_id], map: "Funcao_loja_id_idx")
  @@index([maquina_id], map: "Funcao_maquina_id_idx")
  @@index([setor_id], map: "Funcao_setor_id_idx")
}

model funcaoorcamento {
  id                String    @id @default(cuid())
  orcamento_id      String
  funcao_id         String
  horas_trabalhadas Decimal   @db.Decimal(10, 2)
  custo_total       Decimal   @db.Decimal(10, 2)
  funcao            funcao    @relation(fields: [funcao_id], references: [id], map: "FuncaoOrcamento_funcao_id_fkey")
  orcamento         orcamento @relation(fields: [orcamento_id], references: [id], onDelete: Cascade, map: "FuncaoOrcamento_orcamento_id_fkey")

