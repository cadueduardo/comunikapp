// ---------------------------------------------------------------------------
// Compras e Suprimentos — MVP Fase 1 (solicitação / pedido / histórico)
// ---------------------------------------------------------------------------

enum StatusSolicitacaoCompra {
  RASCUNHO
  SOLICITADA
  APROVADA
  CONVERTIDA
  REJEITADA
  DEVOLVIDA
  CANCELADA
}

enum PrioridadeCompra {
  BAIXA
  NORMAL
  ALTA
  URGENTE
}

enum OrigemNecessidadeCompra {
  MANUAL
  ORDEM_SERVICO
  ITEM_OS
  ORDEM_TERCEIRIZACAO
  ESTOQUE
  MANUTENCAO
  ADMINISTRATIVO
}

enum TipoItemCompra {
  MATERIAL
  SERVICO
  DESPESA
}

enum StatusPedidoCompra {
  RASCUNHO
  EM_APROVACAO
  APROVADO
  REJEITADO
  ENVIADO
  PARCIAL
  ATENDIDO
  CONCLUIDO
  CANCELADO
}

enum DestinoApropriacaoCompra {
  OS
  ITEM_OS
  ESTOQUE
  CENTRO_CUSTO
}

model SolicitacaoCompra {
  id              String                   @id @default(cuid())
  loja_id         String
  numero          String
  status          StatusSolicitacaoCompra  @default(RASCUNHO)
  prioridade      PrioridadeCompra         @default(NORMAL)
  origem_tipo     OrigemNecessidadeCompra  @default(MANUAL)
  origem_id       String?
  solicitante_id  String
  justificativa   String?                  @db.Text
  data_necessaria DateTime?
  criado_em       DateTime                 @default(now())
  atualizado_em   DateTime                 @updatedAt

  loja        loja                   @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  solicitante usuario                @relation("SolicitacaoCompraSolicitante", fields: [solicitante_id], references: [id], onDelete: Restrict)
  itens       SolicitacaoCompraItem[]

  @@unique([loja_id, numero])
  @@index([loja_id, status])
  @@index([loja_id, origem_tipo, origem_id])
  @@index([solicitante_id])
  @@map("solicitacoes_compra")
}

model SolicitacaoCompraItem {
  id                      String         @id @default(cuid())
  loja_id                 String
  solicitacao_id          String
  tipo                    TipoItemCompra
  insumo_id               String?
  descricao               String
  quantidade              Decimal        @db.Decimal(12, 3)
  unidade                 String
  item_os_id              String?
  ordem_terceirizacao_id  String?
  criado_em               DateTime       @default(now())

  solicitacao         SolicitacaoCompra  @relation(fields: [solicitacao_id], references: [id], onDelete: Cascade)
  insumo              Insumo?            @relation(fields: [insumo_id], references: [id], onDelete: Restrict)
  item_os             ItemOS?            @relation(fields: [item_os_id], references: [id], onDelete: SetNull)
  ordem_terceirizacao OrdemTerceirizacao? @relation(fields: [ordem_terceirizacao_id], references: [id], onDelete: SetNull)
  pedido_itens        PedidoCompraItem[]

  @@index([loja_id])
  @@index([solicitacao_id])
  @@index([insumo_id])
  @@index([item_os_id])
  @@index([ordem_terceirizacao_id])
  @@map("solicitacao_compra_itens")
}

model PedidoCompra {
  id                     String             @id @default(cuid())
  loja_id                String
  numero                 String
  fornecedor_id          String
  status                 StatusPedidoCompra @default(RASCUNHO)
  pedido_substituido_id  String?
  motivo_substituicao    String?            @db.Text
  moeda                  String             @default("BRL") @db.VarChar(3)
  subtotal               Decimal            @default(0) @db.Decimal(12, 2)
  desconto               Decimal            @default(0) @db.Decimal(12, 2)
  frete                  Decimal            @default(0) @db.Decimal(12, 2)
  total                  Decimal            @default(0) @db.Decimal(12, 2)
  data_emissao           DateTime?
  data_prevista          DateTime?
  condicao_pagamento     String?            @db.VarChar(255)
  observacoes            String?            @db.Text
  aprovado_por           String?
  aprovado_em            DateTime?
  enviado_em             DateTime?
  cancelado_em           DateTime?
  cancelado_por          String?
  motivo_cancelamento    String?            @db.Text
  versao                 Int                @default(1)
  criado_em              DateTime           @default(now())
  atualizado_em          DateTime           @updatedAt

  loja               loja            @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  fornecedor         fornecedor      @relation(fields: [fornecedor_id], references: [id], onDelete: Restrict)
  pedido_substituido PedidoCompra?   @relation("PedidoCompraSubstituicao", fields: [pedido_substituido_id], references: [id], onDelete: SetNull)
  pedidos_substitutos PedidoCompra[] @relation("PedidoCompraSubstituicao")
  itens              PedidoCompraItem[]

  @@unique([loja_id, numero])
  @@index([loja_id, status])
  @@index([loja_id, fornecedor_id])
  @@index([pedido_substituido_id])
  @@map("pedidos_compra")
}

model PedidoCompraItem {
  id                     String         @id @default(cuid())
  loja_id                String
  pedido_id              String
  solicitacao_item_id    String?
  tipo                   TipoItemCompra
  insumo_id              String?
  ordem_terceirizacao_id String?
  descricao_snapshot     String
  codigo_ref_snapshot    String?
  quantidade             Decimal        @db.Decimal(12, 3)
  unidade_snapshot       String
  preco_unitario         Decimal        @db.Decimal(12, 4)
  desconto               Decimal        @default(0) @db.Decimal(12, 2)
  frete_rateado          Decimal        @default(0) @db.Decimal(12, 2)
  total                  Decimal        @db.Decimal(12, 2)
  quantidade_recebida    Decimal        @default(0) @db.Decimal(12, 3)
  quantidade_aceita      Decimal        @default(0) @db.Decimal(12, 3)
  criado_em              DateTime       @default(now())
  atualizado_em          DateTime       @updatedAt

  pedido              PedidoCompra                 @relation(fields: [pedido_id], references: [id], onDelete: Cascade)
  solicitacao_item    SolicitacaoCompraItem?       @relation(fields: [solicitacao_item_id], references: [id], onDelete: SetNull)
  insumo              Insumo?                      @relation(fields: [insumo_id], references: [id], onDelete: Restrict)
  ordem_terceirizacao OrdemTerceirizacao?          @relation("PedidoCompraItemOrdemTerceirizacao", fields: [ordem_terceirizacao_id], references: [id], onDelete: SetNull)
  apropriacoes        PedidoCompraItemApropriacao[]

  @@index([loja_id])
  @@index([pedido_id])
  @@index([solicitacao_item_id])
  @@index([insumo_id])
  @@index([ordem_terceirizacao_id])
  @@map("pedido_compra_itens")
}

model PedidoCompraItemApropriacao {
  id             String                    @id @default(cuid())
  loja_id        String
  pedido_item_id String
  destino_tipo   DestinoApropriacaoCompra
  os_id          String?
  item_os_id     String?
  centro_custo   String?
  percentual     Decimal?                  @db.Decimal(5, 2)
  valor_previsto Decimal                   @db.Decimal(12, 2)
  criado_em      DateTime                  @default(now())
  atualizado_em  DateTime                  @updatedAt

  pedido_item PedidoCompraItem @relation(fields: [pedido_item_id], references: [id], onDelete: Cascade)
  os          OrdemServico?    @relation(fields: [os_id], references: [id], onDelete: SetNull)
  item_os     ItemOS?          @relation("PedidoCompraApropriacaoItemOS", fields: [item_os_id], references: [id], onDelete: SetNull)

  @@index([loja_id])
  @@index([pedido_item_id])
  @@index([os_id])
  @@index([item_os_id])
  @@map("pedido_compra_item_apropriacoes")
}

model CompraHistorico {
  id              String   @id @default(cuid())
  loja_id         String
  entidade_tipo   String   @db.VarChar(64)
  entidade_id     String
  acao            String   @db.VarChar(64)
  status_anterior String?  @db.VarChar(32)
  status_novo     String?  @db.VarChar(32)
  dados           Json?
  usuario_id      String?
  ip              String?
  user_agent      String?  @db.VarChar(512)
  criado_em       DateTime @default(now())

  loja    loja     @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  usuario usuario? @relation("CompraHistoricoUsuario", fields: [usuario_id], references: [id], onDelete: SetNull)

  @@index([loja_id, entidade_tipo, entidade_id])
  @@index([loja_id, criado_em])
  @@index([usuario_id])
  @@map("compras_historico")
}

model maquina {
  id                                  String                   @id @default(cuid())
  criado_em                           DateTime                 @default(now())
  atualizado_em                       DateTime                 @updatedAt
  nome                                String
  tipo                                String
  custo_hora                          Decimal                  @db.Decimal(10, 2)
  status                              String                   @default("ATIVA")
  ativo                               Boolean                  @default(true) // Campo para V2
  capacidade                          String?
  observacoes                         String?                  @db.Text
  loja_id                             String
  setor_id                            String? // Setor ao qual a máquina pertence
  funcao                              funcao[]
  loja                                loja                     @relation(fields: [loja_id], references: [id], onDelete: Cascade, map: "Maquina_loja_id_fkey")
  setor                               SetorProdutivo?          @relation(fields: [setor_id], references: [id], onDelete: SetNull, map: "Maquina_setor_id_fkey")
  maquinas_template                   MaquinaTemplateProduto[]
  maquinaorcamento                    maquinaorcamento[]
  itemMaquina                         ItemMaquina[]
  modo_producao                       maquina_modo_producao    @default(M2_H)
  setup_min                           Decimal?                 @db.Decimal(10, 2)
  velocidade_m2_h                     Decimal?                 @db.Decimal(10, 2)
  // Velocidade em metros lineares por hora, usada quando modo_producao = ML_H
  // Tipico para router CNC, plotter de corte, laser etc. (Fase 2)
  velocidade_ml_h                     Decimal?                 @db.Decimal(10, 2)
  eficiencia_percent                  Decimal?                 @db.Decimal(5, 2)
  usar_no_pcp                         Boolean                  @default(true)
  horas_disponiveis_dia               Decimal?                 @db.Decimal(5, 2)
  dias_produtivos                     String?                  @db.LongText
  permite_agendamento_simultaneo      Boolean                  @default(false)
  tempo_minimo_entre_servicos_min     Int?
  considerar_eficiencia_na_capacidade Boolean                  @default(true)

  @@index([loja_id], map: "Maquina_loja_id_idx")
  @@index([loja_id, tipo], map: "Maquina_loja_id_tipo_idx")
  @@index([setor_id], map: "Maquina_setor_id_idx")
}

model maquinaorcamento {
  id               String    @id @default(cuid())
  orcamento_id     String
  maquina_id       String
  horas_utilizadas Decimal   @db.Decimal(10, 2)
  custo_total      Decimal   @db.Decimal(10, 2)
  maquina          maquina   @relation(fields: [maquina_id], references: [id], map: "MaquinaOrcamento_maquina_id_fkey")
  orcamento        orcamento @relation(fields: [orcamento_id], references: [id], onDelete: Cascade, map: "MaquinaOrcamento_orcamento_id_fkey")

  @@index([maquina_id], map: "MaquinaOrcamento_maquina_id_idx")
  @@index([orcamento_id], map: "MaquinaOrcamento_orcamento_id_idx")
}

model mensagemnegociacao {
  id           String    @id @default(cuid())
  orcamento_id String
