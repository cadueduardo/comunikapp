  permitir_edicao_orcamentista Boolean  @default(true)
  criado_em                    DateTime @default(now())
  atualizado_em                DateTime @updatedAt

  loja         loja            @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  servico_arte servico_manual? @relation(fields: [servico_arte_id], references: [id], onDelete: SetNull)

  @@index([servico_arte_id])
  @@map("configuracao_arte_loja")
}

// Hub de integrações externas por loja (OAuth, APIs)
model LojaConexao {
  id                String   @id @default(cuid())
  loja_id           String
  tipo              String   @db.VarChar(32)
  status            String   @default("DESCONECTADO") @db.VarChar(32)
  configuracao_json Json?
  criado_em         DateTime @default(now())
  atualizado_em     DateTime @updatedAt

  loja loja @relation(fields: [loja_id], references: [id], onDelete: Cascade)

  @@unique([loja_id, tipo])
  @@index([loja_id, tipo])
  @@index([loja_id, status])
  @@map("loja_conexao")
}

model ArteVersao {
  id                   String     @id @default(cuid())
  os_id                String
  servico_id           String? // Referência ao serviço específico
  versao               String // v1, v2, v3, etc.
  status               ArteStatus
  autor_id             String
  descricao            String?
  observacoes          String?
  data_criacao         DateTime   @default(now())
  data_aprovacao       DateTime?
  aprovado_por         String?
  aprovado_por_cliente Boolean    @default(false)
  liberado_para_pcp    Boolean    @default(false) // Liberação final do designer após aprovação do cliente
  liberado_em          DateTime? // Data em que o designer liberou para PCP
  liberado_por         String? // ID do designer que liberou
  loja_id              String // Multi-tenant

  // Soft Delete
  deletado      Boolean   @default(false)
  data_exclusao DateTime?
  excluido_por  String?

  // Relacionamentos
  os              OrdemServico        @relation(fields: [os_id], references: [id], onDelete: Cascade)
  autor           usuario             @relation("ArteAutor", fields: [autor_id], references: [id])
  aprovador       usuario?            @relation("ArteAprovador", fields: [aprovado_por], references: [id])
  liberador       usuario?            @relation("ArteLiberador", fields: [liberado_por], references: [id])
  excluidor       usuario?            @relation("ArteExcluidor", fields: [excluido_por], references: [id])
  arquivos        ArteArquivo[]
  comentarios     ArteComentario[]
  links_aprovacao ArteLinkAprovacao[]
  mensagens       ArteMensagem[]

  @@index([os_id, loja_id])
  @@index([status, loja_id])
  @@index([autor_id, loja_id])
  @@index([deletado, loja_id])
  @@index([aprovado_por])
  @@index([liberado_por])
  @@index([excluido_por])
  @@map("arte_versoes")
}

model ArteArquivo {
  id               String   @id @default(cuid())
  versao_id        String
  nome_arquivo     String
  nome_original    String
  tipo_arquivo     String // pdf, jpg, png, ai, etc.
  tamanho          BigInt
  url_arquivo      String
  url_thumbnail    String? // Para preview
  storage_provider String // google_drive, aws_s3, local
  storage_path     String
  data_upload      DateTime @default(now())
  loja_id          String // Multi-tenant

  // Relacionamentos
  versao ArteVersao @relation(fields: [versao_id], references: [id], onDelete: Cascade)

  @@index([versao_id, loja_id])
  @@index([tipo_arquivo, loja_id])
  @@map("arte_arquivos")
}

model ArteComentario {
  id              String         @id @default(cuid())
  versao_id       String
  usuario_id      String
  comentario      String         @db.LongText
  tipo            ComentarioTipo @default(INTERNO)
  data_comentario DateTime       @default(now())
  loja_id         String // Multi-tenant

  // Relacionamentos
  versao  ArteVersao @relation(fields: [versao_id], references: [id], onDelete: Cascade)
  usuario usuario    @relation(fields: [usuario_id], references: [id])

  @@index([versao_id, loja_id])
  @@index([usuario_id, loja_id])
  @@map("arte_comentarios")
}

model ArteLinkAprovacao {
  id                 String    @id @default(cuid())
  versao_id          String
  token_publico      String    @unique
  expira_em          DateTime
  aprovado           Boolean   @default(false)
  data_aprovacao     DateTime?
  ip_aprovacao       String?
  user_agent         String?
  comentario_cliente String?   @db.LongText
  ativo              Boolean   @default(true)
  loja_id            String // Multi-tenant

  // Relacionamentos
  versao ArteVersao @relation(fields: [versao_id], references: [id], onDelete: Cascade)

  @@index([token_publico])
  @@index([loja_id])
  @@index([expira_em])
  @@index([versao_id])
  @@map("arte_links_aprovacao")
}

model ArteMensagem {
  id           String    @id @default(cuid())
  os_id        String
  produto_id   String // ID do produto específico
  versao_id    String? // ID da versão (opcional)
  mensagem     String    @db.LongText
  autor_tipo   AutorTipo
  autor_nome   String
  autor_email  String?
  lida         Boolean   @default(false)
  data_leitura DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  loja_id      String // Multi-tenant

  // Relacionamentos
  os     OrdemServico @relation(fields: [os_id], references: [id], onDelete: Cascade)
  versao ArteVersao?  @relation(fields: [versao_id], references: [id], onDelete: SetNull)

  @@index([os_id, produto_id, loja_id])
  @@index([autor_tipo, loja_id])
  @@index([lida, loja_id])
  @@index([created_at, loja_id])
  @@index([versao_id])
  @@map("arte_mensagens")
}

enum ArteStatus {
  RASCUNHO
  ENVIADA_CLIENTE
  APROVADA
  REVISAO_SOLICITADA
  BLOQUEADA
  ENVIADA_PCP
}

enum ComentarioTipo {
  INTERNO
  CLIENTE
  SISTEMA
}

enum AutorTipo {
  CLIENTE
  EQUIPE
}

// ==========================================
// MODULO HOME OPERACIONAL - Fase 1
// ==========================================

// Onboarding operacional por loja. Cada etapa do checklist e detectada
// automaticamente por consulta ao banco; o usuario apenas marca como
// "ignorada" ou reativa. Ver docs/fase-0-home-operacional/03-onboarding-etapas.md
model OnboardingOperacional {
  id            String    @id @default(cuid())
  loja_id       String
  step_id       String    @db.VarChar(64)
  // 'pendente' | 'concluido' | 'ignorado' | 'atencao'
  status        String    @default("pendente") @db.VarChar(16)
  concluido_em  DateTime?
  ignorado_em   DateTime?
  criado_em     DateTime  @default(now())
  atualizado_em DateTime  @updatedAt

  loja loja @relation(fields: [loja_id], references: [id], onDelete: Cascade)

  @@unique([loja_id, step_id])
  @@index([loja_id])
  @@index([status])
  @@map("onboarding_operacional")
}

// ==========================================
// MÓDULO PRODUTOS (PRATELEIRA / REVENDA)
// ==========================================

model CategoriaProdutoFinito {
  id            String   @id @default(uuid())
  loja_id       String
  nome          String   @db.VarChar(100)
  ativo         Boolean  @default(true)
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  loja     loja            @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  produtos ProdutoFinito[]

  @@unique([loja_id, nome])
  @@index([loja_id])
  @@map("categorias_produto_finito")
}

model ProdutoFinito {
  id                 String            @id @default(uuid())
  loja_id            String
  categoria_id       String?
  sku                String            @db.VarChar(50)
  ean                String?           @db.VarChar(13)
  nome               String            @db.VarChar(255)
  descricao_resumida String?           @db.VarChar(500)
  descricao          String?           @db.Text
  preco_venda        Decimal           @db.Decimal(10, 2)
  preco_promocional  Decimal?          @db.Decimal(10, 2)
  preco_custo        Decimal?          @db.Decimal(10, 2)
  peso_kg            Decimal           @default(0) @db.Decimal(10, 3)
  largura_cm         Int               @default(0)
  altura_cm          Int               @default(0)
  profundidade_cm    Int               @default(0)
  estoque_atual      Int               @default(0)
  estoque_minimo     Int               @default(0)
  ativo              Boolean           @default(true)
  personalizavel     Boolean           @default(false)
  fulfillment_padrao FulfillmentPadrao @default(ESTOQUE)
  criado_em          DateTime          @default(now())
  atualizado_em      DateTime          @updatedAt

  loja            loja                    @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  categoria       CategoriaProdutoFinito? @relation(fields: [categoria_id], references: [id], onDelete: SetNull)
  imagens         GaleriaProdutoFinito[]
  itens_orcamento ProdutoOrcamento[]
  modos           ProdutoFinitoModo[]
  estampas        ProdutoFinitoEstampa[]
  processos       ProdutoFinitoProcesso[]

  @@unique([loja_id, sku])
  @@index([loja_id])
  @@index([loja_id, id])
  @@index([loja_id, personalizavel])
  @@index([categoria_id])
  @@map("produtos_finitos")
}

model GaleriaProdutoFinito {
  id                String @id @default(uuid())
  produto_finito_id String
  url_imagem        String @db.Text
  ordem             Int    @default(0)

  produto ProdutoFinito @relation(fields: [produto_finito_id], references: [id], onDelete: Cascade)

  @@index([produto_finito_id])
  @@map("galeria_produto_finito")
}

// ==========================================
// MÓDULO CATÁLOGO — PERSONALIZAÇÃO E ESTAMPAS
// ==========================================

enum CampoVariavelTipo {
  TEXTO
  NUMERO
  DATA
}

enum ModoPersonalizacao {
  NENHUM
  ESTAMPA
  IMPRINT_LIVRE
  ARTE_SOB_MEDIDA
}

enum FulfillmentPadrao {
  ESTOQUE
  PRODUCAO
  HIBRIDO
}

enum ModoFulfillmentItem {
  PICK
  MAKE
  HIBRIDO
  OUTSOURCE
}

model ProcessoDecoracao {
  id                  String   @id @default(cuid())
  loja_id             String
  codigo              String?  @db.VarChar(50)
  nome                String   @db.VarChar(120)
  descricao           String?  @db.Text
  exige_arte_aprovada Boolean  @default(false)
  insumos_aceitos     Json // ["ARQUIVO","TEXTO","VETOR"]
  preco_base          Decimal? @db.Decimal(10, 2)
  custo_setup         Decimal  @default(0) @db.Decimal(10, 2)
  faixas_preco        Json // Quantity Breaks: [{ min, max, preco }]
  setor_pcp_sugerido  String?  @db.VarChar(120)
  ativo               Boolean  @default(true)
  criado_em           DateTime @default(now())
  atualizado_em       DateTime @updatedAt

  loja                loja                      @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  estampas            Estampa[]
  produtos_vinculados ProdutoFinitoProcesso[]
  personalizacoes     PersonalizacaoOrcamento[]

  @@unique([loja_id, codigo])
  @@index([loja_id])
  @@index([loja_id, id])
  @@index([loja_id, ativo])
  @@map("processos_decoracao")
}

model ConjuntoCampos {
  id            String   @id @default(cuid())
  loja_id       String
  nome          String   @db.VarChar(120)
  descricao     String?  @db.Text
  ativo         Boolean  @default(true)
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  loja     loja               @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  campos   CampoVariavelDef[]
  estampas Estampa[]

  @@unique([loja_id, nome])
  @@index([loja_id])
  @@index([loja_id, id])
  @@index([loja_id, ativo])
  @@map("conjuntos_campos")
}

model CampoVariavelDef {
  id             String            @id @default(cuid())
  conjunto_id    String
  chave          String            @db.VarChar(64)
  label          String            @db.VarChar(120)
  tipo           CampoVariavelTipo @default(TEXTO)
  obrigatorio    Boolean           @default(true)
  max_caracteres Int?
  fonte_sugerida String?           @db.VarChar(120)
  ordem          Int               @default(0)
  placeholder    String?           @db.VarChar(255)
  criado_em      DateTime          @default(now())
  atualizado_em  DateTime          @updatedAt

  conjunto ConjuntoCampos @relation(fields: [conjunto_id], references: [id], onDelete: Cascade)

  @@unique([conjunto_id, chave])
  @@index([conjunto_id])
  @@map("campos_variaveis_def")
}

model Estampa {
  id                 String   @id @default(cuid())
  loja_id            String
  codigo             String?  @db.VarChar(50)
  nome               String   @db.VarChar(255)
  processo_id        String
  conjunto_campos_id String?
  arte_mestra_url    String?  @db.Text
  thumb_url          String?  @db.Text
  preco_adicional    Decimal  @default(0) @db.Decimal(10, 2)
  metadados          Json? // âncoras / bounding boxes para VDP
  ativo              Boolean  @default(true)
  criado_em          DateTime @default(now())
  atualizado_em      DateTime @updatedAt

  loja            loja                      @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  processo        ProcessoDecoracao         @relation(fields: [processo_id], references: [id], onDelete: Restrict)
  conjunto_campos ConjuntoCampos?           @relation(fields: [conjunto_campos_id], references: [id], onDelete: SetNull)
  produtos        ProdutoFinitoEstampa[]
  itens_os        ItemOS[]
  personalizacoes PersonalizacaoOrcamento[]

  @@unique([loja_id, codigo])
  @@index([loja_id])
  @@index([loja_id, id])
  @@index([loja_id, ativo])
  @@index([processo_id])
  @@index([conjunto_campos_id])
  @@map("estampas")
}

model ProdutoFinitoModo {
  id                String             @id @default(cuid())
  loja_id           String
  produto_finito_id String
  modo              ModoPersonalizacao
  habilitado        Boolean            @default(true)
  criado_em         DateTime           @default(now())

  produto ProdutoFinito @relation(fields: [produto_finito_id], references: [id], onDelete: Cascade)

  @@unique([produto_finito_id, modo])
  @@index([loja_id])
  @@index([loja_id, produto_finito_id])
  @@index([produto_finito_id])
  @@map("produto_finito_modos")
}

model ProdutoFinitoEstampa {
  loja_id           String
  produto_finito_id String
  estampa_id        String
  criado_em         DateTime @default(now())

  produto ProdutoFinito @relation(fields: [produto_finito_id], references: [id], onDelete: Cascade)
  estampa Estampa       @relation(fields: [estampa_id], references: [id], onDelete: Cascade)

  @@id([produto_finito_id, estampa_id])
  @@index([loja_id])
  @@index([loja_id, estampa_id])
  @@index([estampa_id])
  @@map("produto_finito_estampas")
}

model ProdutoFinitoProcesso {
  loja_id           String
  produto_finito_id String
  processo_id       String
  criado_em         DateTime @default(now())

  produto  ProdutoFinito     @relation(fields: [produto_finito_id], references: [id], onDelete: Cascade)
  processo ProcessoDecoracao @relation(fields: [processo_id], references: [id], onDelete: Cascade)

  @@id([produto_finito_id, processo_id])
  @@index([loja_id])
  @@index([loja_id, processo_id])
  @@index([processo_id])
  @@map("produto_finito_processos")
}

model PersonalizacaoOrcamento {
  id                   String             @id @default(cuid())
  loja_id              String
  produto_orcamento_id String             @unique
  modo                 ModoPersonalizacao @default(NENHUM)
  estampa_id           String?
  processo_id          String?
  valores_campos       Json? // polimórfico: Record<string,string> | Record<string,string>[]
  grade_distribuicao   Json? // matriz de atributos
  arte_producao_url    String?            @db.Text
  preview_url          String?            @db.Text
  criado_em            DateTime           @default(now())
  atualizado_em        DateTime           @updatedAt

  produto_orcamento ProdutoOrcamento   @relation(fields: [produto_orcamento_id], references: [id], onDelete: Cascade)
  estampa           Estampa?           @relation(fields: [estampa_id], references: [id], onDelete: SetNull)
  processo          ProcessoDecoracao? @relation(fields: [processo_id], references: [id], onDelete: SetNull)

  @@index([loja_id])
  @@index([loja_id, id])
  @@index([estampa_id])
  @@index([processo_id])
  @@map("personalizacao_orcamento")
}
