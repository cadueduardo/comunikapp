model orcamento {
  id                     String   @id @default(cuid())
  criado_em              DateTime @default(now())
  atualizado_em          DateTime
  numero                 String
  nome_servico           String
  descricao              String?  @db.Text
  horas_producao         Decimal  @db.Decimal(10, 2)
  custo_material         Decimal  @db.Decimal(10, 2)
  custo_mao_obra         Decimal  @db.Decimal(10, 2)
  custo_indireto         Decimal  @db.Decimal(10, 2)
  custo_total            Decimal  @db.Decimal(10, 2)
  margem_lucro           Decimal  @db.Decimal(10, 2)
  impostos               Decimal  @db.Decimal(10, 2)
  preco_final            Decimal  @db.Decimal(10, 2)
  loja_id                String
  cliente_id             String?
  altura_produto         Decimal? @db.Decimal(10, 2)
  area_produto           Decimal? @db.Decimal(10, 2)
  largura_produto        Decimal? @db.Decimal(10, 2)
  quantidade_produto     Decimal? @db.Decimal(10, 2)
  unidade_medida_produto String?
  observacoes_cliente    String?  @db.Text
  status_aprovacao       String?  @default("PENDENTE")
  codigo_aprovacao       String?  @unique(map: "Orcamento_codigo_aprovacao_key")
  status                 String?  @default("rascunho")
  atendente              String?  @default("Equipe Comercial")
  // DEPRECATED (Fase 6 - 2026-05-25): campo de texto livre substituido pelos campos estruturados
  // condicao_pagamento_tipo / percentual_entrada / valor_entrada / valor_saldo / vencimento_*.
  // Mantido para compatibilidade com orcamentos antigos; nao deve mais ser gravado pelos novos fluxos.
  // Sera removido em migration futura quando 100% dos orcamentos estiverem migrados.
  forma_pagamento        String?  @default("50% entrada, restante na entrega")
  prazo_entrega          String?  @default("10 a 15 dias úteis")
  validade_proposta      String?  @default("30 dias")

  // Fase 6 - Financeiro minimo: campos estruturados de condicao de pagamento.
  // Tipos: A_VISTA, ENTRADA_SALDO, FATURADO_30, FATURADO_60, FATURADO_90, PARCELADO, PERSONALIZADO.
  condicao_pagamento_tipo        String?  @db.VarChar(32)
  // Percentual de entrada (0-100); aplicavel a ENTRADA_SALDO. Para PARCELADO/PERSONALIZADO,
  // as parcelas sao gravadas na tabela `cobranca_parcela`.
  condicao_pagamento_entrada_pct Decimal? @db.Decimal(5, 2)
  // Numero de parcelas; aplicavel a PARCELADO (>=2).
  condicao_pagamento_parcelas    Int?
  // Descricao livre; obrigatorio em PERSONALIZADO, opcional nos demais (override do texto auto-gerado).
  condicao_pagamento_descricao   String?  @db.VarChar(255)
  comissao_percentual            Decimal? @db.Decimal(5, 2)
  tipo_margem_lucro              String?  @db.VarChar(24) // 'markup' | 'margem_por_dentro' por orçamento

  // Entrega/frete comercial do orçamento. Snapshot preserva o histórico do orçamento.
  entrega_modalidade_id         String?
  entrega_usar_endereco_cliente Boolean  @default(true)
  entrega_endereco_snapshot     String?  @db.LongText
  entrega_cep                   String?  @db.VarChar(16)
  entrega_logradouro            String?  @db.VarChar(255)
  entrega_numero                String?  @db.VarChar(32)
  entrega_complemento           String?  @db.VarChar(255)
  entrega_bairro                String?  @db.VarChar(120)
  entrega_cidade                String?  @db.VarChar(120)
  entrega_estado                String?  @db.VarChar(2)
  entrega_prazo_dias            Int?
  entrega_valor_cobrado         Decimal? @db.Decimal(12, 2)
  entrega_custo_estimado        Decimal? @db.Decimal(12, 2)
  entrega_observacoes           String?  @db.Text

  // Campos V2
  titulo               String? // Título do orçamento
  responsavel_id       String?
  prioridade           String?   @default("NORMAL")
  tipo_orcamento       String?   @default("PRODUTO")
  condicoes_comerciais String?   @db.Text
  observacoes_internas String?   @db.Text
  tags                 String?   @db.Text
  data_limite          DateTime?
  data_aprovacao       DateTime?
  aprovado_por         String?
  motivo_rejeicao      String?   @db.Text
  custos_calculados    String?   @db.LongText // JSON com custos detalhados
  configuracao_calculo String?   @db.LongText // JSON com configurações
  versao_atual         Int       @default(1)
  ativo                Boolean   @default(true)
  valor_total          Decimal?  @db.Decimal(10, 2)
  data_criacao         DateTime  @default(now())
  data_atualizacao     DateTime  @updatedAt
  ordem                Int       @default(0)
  categoria            String?
  detalhamento_calculo String?   @db.LongText // JSON com detalhamento
  alertas              String?   @db.LongText // JSON com alertas
  data_ultimo_calculo  DateTime?

  funcaoorcamento              funcaoorcamento[]
  itemorcamento                itemorcamento[]
  maquinaorcamento             maquinaorcamento[]
  mensagemnegociacao           mensagemnegociacao[]
  notificacao                  notificacao[]
  cliente                      cliente?                    @relation(fields: [cliente_id], references: [id], map: "Orcamento_cliente_id_fkey")
  entrega_modalidade           ModalidadeEntrega?          @relation(fields: [entrega_modalidade_id], references: [id], map: "Orcamento_entrega_modalidade_id_fkey")
  loja                         loja                        @relation(fields: [loja_id], references: [id], onDelete: Cascade, map: "Orcamento_loja_id_fkey")
  responsavel                  usuario?                    @relation(fields: [responsavel_id], references: [id])
  historico                    OrcamentoHistorico[]
  logs                         OrcamentoLog[]
  produtos                     ProdutoOrcamento[]
  historicoOrcamento           HistoricoOrcamento[]
  versoes                      VersaoOrcamento[]
  mensagensChat                MensagemChat[]
  linksPublicos                LinkPublico[]
  aprovacoes                   aprovacaoOrcamento[]
  execucoes_regras             ExecucaoRegra[]
  custos                       String?                     @db.LongText // JSON com custos detalhados
  ordens_servico               OrdemServico[]
  cobranca                     Cobranca? // Fase 6 - relacao 1:1 com cobranca
  orcamento_aditivo_instalacao OrcamentoAditivoInstalacao?

  // Campos para soft delete
  excluido_em     DateTime?
  excluido_por    String?
  motivo_exclusao String?   @db.Text

  @@unique([loja_id, numero], map: "Orcamento_loja_id_numero_key")
  @@index([cliente_id], map: "Orcamento_cliente_id_fkey")
  @@index([loja_id], map: "Orcamento_loja_id_idx")
  @@index([loja_id, numero], map: "Orcamento_loja_id_numero_idx")
  @@index([responsavel_id])
  @@index([entrega_modalidade_id])
  @@index([status])
  @@index([tipo_orcamento])
  @@index([ativo])
}

// Tabelas V2 para múltiplos produtos
model ProdutoOrcamento {
  id                   String   @id @default(cuid())
  orcamento_id         String
  nome_servico         String
  descricao            String?  @db.Text
  quantidade           Decimal  @db.Decimal(10, 3)
  largura              Decimal? @db.Decimal(10, 2)
  altura               Decimal? @db.Decimal(10, 2)
  profundidade         Decimal? @db.Decimal(10, 2) // Campo para produtos 3D (totens, letras caixa)
  area_produto         Decimal? @db.Decimal(10, 2)
  unidade_medida       String?
  custo_total_producao Decimal  @db.Decimal(10, 2)
  preco_unitario       Decimal  @db.Decimal(10, 2)
  preco_total          Decimal  @db.Decimal(10, 2)
  margem_lucro         Decimal  @db.Decimal(10, 2)
  impostos             Decimal  @db.Decimal(10, 2)
  observacoes          String?  @db.Text
  ativo                Boolean  @default(true)
  criado_em            DateTime @default(now())
  atualizado_em        DateTime @updatedAt
  data_criacao         DateTime @default(now())
  data_atualizacao     DateTime @updatedAt
  ordem                Int      @default(0)
  categoria            String?
  nome                 String? // Campo para V2

  // Instalação/aplicação vendida junto ao produto. Snapshot alimenta a OS futura.
  instalacao_necessaria            Boolean  @default(false)
  instalacao_tipo_id               String?
  instalacao_regra_cobranca        String?  @db.VarChar(24)
  instalacao_valor_unitario        Decimal? @db.Decimal(12, 2)
  instalacao_usar_endereco_entrega Boolean  @default(true)
  instalacao_endereco_snapshot     String?  @db.LongText
  instalacao_cep                   String?  @db.VarChar(16)
  instalacao_logradouro            String?  @db.VarChar(255)
  instalacao_numero                String?  @db.VarChar(32)
  instalacao_complemento           String?  @db.VarChar(255)
  instalacao_bairro                String?  @db.VarChar(120)
  instalacao_cidade                String?  @db.VarChar(120)
  instalacao_estado                String?  @db.VarChar(2)
  instalacao_preco_cobrado         Decimal? @db.Decimal(12, 2)
  instalacao_custo_mao_obra        Decimal? @db.Decimal(12, 2)
  instalacao_custo_deslocamento    Decimal? @db.Decimal(12, 2)
  instalacao_tempo_estimado_min    Int?
  instalacao_quantidade_pessoas    Int?
  instalacao_observacoes           String?  @db.Text

  // Geometria avancada (Fase 2 - Home operacional)
  // Ver docs/fase-0-home-operacional/04-campos-geometria.md
  // Perimetro em milimetros (para estimativa de tempo de corte).
  perimetro_produto           Decimal? @db.Decimal(10, 2)
  // Unidade original informada na geometria (mm | cm | m). NULL em registros
  // anteriores à Fase 2.F; o frontend assume mm e pede confirmação.
  unidade_geometria           String?  @db.VarChar(4)
  // 'MANUAL' | 'IMAGEM' | 'DXF' (string controlada por codigo)
  geometria_origem            String?  @db.VarChar(16)
  arquivo_geometria_url       String?  @db.VarChar(512)
  arquivo_geometria_metadados String?  @db.LongText // JSON

  // Módulo Arte & Aprovação (orçamento)
  responsabilidade_arte      String   @default("NAO_APLICAVEL") @db.VarChar(32)
  politica_cobranca_arte     String   @default("NAO_APLICAVEL") @db.VarChar(32)
  finalidade_anexo           String?  @db.VarChar(32)
  complexidade_arte          String?  @db.VarChar(16)
  arte_custo_automatico      Boolean  @default(false)
  arte_referencia_servico_id String?  @db.VarChar(191)
  arte_horas_calculadas      Decimal? @db.Decimal(10, 2)
  arte_custo_calculado       Decimal? @db.Decimal(10, 2)

  // Módulo Produtos (prateleira) — integração com orçamento V2
  // SOB_DEMANDA: cálculo via motor V2 (padrão legado)
  // PRODUTO_FINITO: preço snapshot em preco_unitario/preco_total; bypass do motor
  tipo_item         String  @default("SOB_DEMANDA") @db.VarChar(20)
  produto_finito_id String?

  // Terceirização definida comercialmente no orçamento. Os custos são
  // snapshots da cotação escolhida e não dependem de alterações futuras no cadastro.
  modo_fulfillment                ModoFulfillmentItem?
  fornecedor_terceirizado_id      String?
  terceirizacao_modelo_custo      ModeloCustoTerceirizacao @default(DETALHADO)
  terceirizacao_quantidade_cotada Decimal?                 @db.Decimal(10, 3)
  terceirizacao_custo_unitario    Decimal?                 @db.Decimal(12, 2)
  terceirizacao_custo_setup       Decimal?                 @db.Decimal(12, 2)
  terceirizacao_custo_frete       Decimal?                 @db.Decimal(12, 2)
  terceirizacao_custo_total       Decimal?                 @db.Decimal(12, 2)
  terceirizacao_prazo_dias        Int?
  terceirizacao_observacoes       String?                  @db.Text

  // Relacionamentos
  orcamento               orcamento                @relation(fields: [orcamento_id], references: [id], onDelete: Cascade)
  instalacao_tipo         TipoInstalacao?          @relation(fields: [instalacao_tipo_id], references: [id])
  produto_finito          ProdutoFinito?           @relation(fields: [produto_finito_id], references: [id], onDelete: SetNull)
  fornecedor_terceirizado fornecedor?              @relation(fields: [fornecedor_terceirizado_id], references: [id], onDelete: SetNull, map: "ProdutoOrcamento_fornecedor_terceirizado_id_fkey")
  personalizacao          PersonalizacaoOrcamento?
  insumos                 ItemInsumo[]
  maquinas                ItemMaquina[]
  funcoes                 ItemFuncao[]
  servicos_manuais        ItemServicoManual[]
  custos_indiretos        ItemCustoIndireto[]

  @@index([orcamento_id])
  @@index([instalacao_tipo_id])
  @@index([ativo])
  @@index([profundidade])
  @@index([produto_finito_id])
  @@index([tipo_item])
  @@index([modo_fulfillment])
  @@index([fornecedor_terceirizado_id])
}

model ItemInsumo {
