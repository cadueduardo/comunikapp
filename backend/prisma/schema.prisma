enum StatusExpedicao {
  AGUARDANDO_SEPARACAO
  PRONTO_PARA_RETIRADA
  EM_ROTA_DE_ENTREGA
  AGUARDANDO_INSTALACAO
  AGUARDANDO_FECHAMENTO
  ENTREGUE_FINALIZADO
  ARQUIVADO
  DEVOLVIDA
}

enum ModalidadeExpedicao {
  RETIRADA_CLIENTE
  ENTREGA_TRANSPORTADORA
  ENTREGA_FROTA_PROPRIA
  INSTALACAO_NO_LOCAL
}

model ExpedicaoLogistica {
  id              String              @id @default(cuid())
  loja_id         String
  os_id           String
  modalidade      ModalidadeExpedicao @default(RETIRADA_CLIENTE)
  status          StatusExpedicao     @default(AGUARDANDO_SEPARACAO)
  codigo_rastreio String?             @db.VarChar(100)
  data_expedida   DateTime?
  data_conclusao  DateTime?
  recebedor_nome  String?             @db.VarChar(150)
  recebedor_doc   String?             @db.VarChar(50)
  url_assinatura  String?             @db.Text
  observacoes     String?             @db.Text
  criado_em       DateTime            @default(now())
  atualizado_em   DateTime            @updatedAt

  loja          loja         @relation(fields: [loja_id], references: [id], onDelete: Cascade)
  ordem_servico OrdemServico @relation(fields: [os_id], references: [id], onDelete: Cascade)

  // os_id sem @unique: permite histórico DEVOLVIDA e nova expedição após retrabalho.
  // Regra de negócio: no máximo um registro ativo (status != DEVOLVIDA) por OS.
  @@index([loja_id])
  @@index([loja_id, status])
  @@index([loja_id, os_id])
  @@index([os_id])
  @@map("expedicoes_logistica")
}

