  loja_id                      String   @unique
  ativo                        Boolean  @default(true)
  modelo_precificacao          String   @default("HORA") @db.VarChar(24)
  servico_arte_id              String?
  cobranca_padrao              String   @default("INCLUIDA_NO_PRODUTO") @db.VarChar(32)
