# ===== CONFIGURAÇÃO DE TESTE - BANCO NOVO =====

# Database Configuration (BANCO NOVO PARA TESTE)
DATABASE_URL="mysql://comunikapp_test:password123@localhost:3306/comunikapp_teste"

# JWT Configuration
JWT_SECRET="test-jwt-secret-key-2025"
JWT_EXPIRES_IN="7d"

# Mail Configuration
MAIL_HOST="smtp.ethereal.email"
MAIL_PORT=587
MAIL_USER="test@ethereal.email"
MAIL_PASS="test-password"

# App Configuration (PORTAS DIFERENTES)
PORT=3002
NODE_ENV=development

# ===== MÓDULO DE ESTOQUE =====

# Estoque Module Configuration
ESTOQUE_MODULE_ENABLED=true
ESTOQUE_INTERNAL_API_TOKEN="estoque-test-token-2025"
ESTOQUE_ALLOWED_ROLES="ADMINISTRADOR,FINANCEIRO,ESTOQUE,VENDAS"

# Estoque Database (usando o mesmo banco de teste)
ESTOQUE_DATABASE_URL="mysql://comunikapp_test:password123@localhost:3306/comunikapp_teste"

# Estoque Performance Settings
ESTOQUE_DB_CONNECTION_LIMIT=5
ESTOQUE_DB_POOL_TIMEOUT=10000
ESTOQUE_DB_POOL_IDLE_TIMEOUT=5000
ESTOQUE_DEFAULT_LIMIT=10
ESTOQUE_MAX_LIMIT=50
ESTOQUE_CACHE_DURATION=60
ESTOQUE_SLOW_QUERY_THRESHOLD=500

# Estoque Health Checks
ESTOQUE_HEALTH_CHECK_INTERVAL=15000
ESTOQUE_ENABLE_MONITORING=true

# Estoque Validation Settings
ESTOQUE_MAX_LOCATION_CODE_LENGTH=20
ESTOQUE_MAX_LOT_NUMBER_LENGTH=50
ESTOQUE_MAX_DOCUMENT_REF_LENGTH=100
ESTOQUE_MAX_OBSERVATIONS_LENGTH=255

# Estoque Notifications
ESTOQUE_ENABLE_LOW_STOCK_ALERTS=true
ESTOQUE_ENABLE_EXPIRY_ALERTS=true
ESTOQUE_ALERT_THRESHOLD=7

# Estoque Logs
ESTOQUE_LOG_LEVEL="debug"
ESTOQUE_ENABLE_QUERY_LOGS=true
ESTOQUE_ENABLE_PERFORMANCE_LOGS=true

# ===== CONFIGURAÇÕES DE TESTE =====

# File Upload Configuration
UPLOAD_DEST="./uploads-test"
MAX_FILE_SIZE=5242880

# Test Database Reset
TEST_DB_RESET_ON_START=true
