generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/client"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model Loja {
  id                      String    @id @default(uuid())
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  name                    String
  cnpj                    String?   @unique
  email                   String    @unique
  phone                   String?
  address                 String?
  responsavel             String?
  logoUrl                 String?
  gateway_customer_id     String?   @unique
  gateway_subscription_id String?   @unique
  subscription_status     String?
  trial_ends_at           DateTime?
  current_period_ends_at  DateTime?

  usuarios            Usuario[]
  categorias          Categoria[]
  fornecedores        Fornecedore[]
  insumos             Insumo[]
  orcamentos          Orcamento[]
  maquinas            Maquina[]
  funcoes             Funcao[]
  custosIndiretos     CustoIndireto[]
  clientes            Cliente[]
  produtos            Produto[]
  tiposMaterial       TipoMaterial[]
  templateProdutos    TemplateProduto[]
  mensagensNegociacao MensagemNegociacao[]
  notificacoes        Notificacao[]

  // Relacionamentos do estoque
  estoqueLocalizacoes  EstoqueLocalizacao[]
  estoqueItens         EstoqueItem[]
  estoqueMovimentacoes EstoqueMovimentacao[]
  estoqueLotes         EstoqueLote[]

  @@map("Loja")
}

model Usuario {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      Role     @default(VENDAS)
  ativo     Boolean  @default(true)
  lojaId    String

  loja Loja @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@index([lojaId])
  @@map("Usuario")
}

model Categoria {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  nome      String
  lojaId    String

  loja    Loja     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  insumos Insumo[]

  @@index([lojaId])
  @@map("categorias")
}

model Fornecedore {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  nome      String
  cnpj      String?
  email     String?
  telefone  String?
  endereco  String?
  lojaId    String

  loja    Loja     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  insumos Insumo[]

  @@index([lojaId])
  @@map("fornecedores")
}

model Insumo {
  id                      String   @id @default(uuid())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  nome                    String
  descricao               String?
  categoriaId             String
  fornecedoreId           String?
  codigo                  String?
  unidadeCompra           String
  precoUnitario           Decimal  @db.Decimal(10, 2)
  custoUnitario           Decimal  @db.Decimal(10, 2)
  margemLucro             Decimal  @default(0) @db.Decimal(5, 2)
  precoVenda              Decimal  @db.Decimal(10, 2)
  estoqueMinimo           Decimal  @default(0) @db.Decimal(10, 3)
  estoqueAtual            Decimal  @default(0) @db.Decimal(10, 3)
  ativo                   Boolean  @default(true)
  lojaId                  String
  largura                 Decimal? @db.Decimal(10, 2)
  altura                  Decimal? @db.Decimal(10, 2)
  espessura               Decimal? @db.Decimal(10, 2)
  peso                    Decimal? @db.Decimal(10, 2)
  unidadeMedida           String?
  area                    Decimal? @db.Decimal(10, 2)
  volume                  Decimal? @db.Decimal(10, 2)
  consumoPorMetroQuadrado Decimal? @db.Decimal(10, 3)
  consumoPorMetroLinear   Decimal? @db.Decimal(10, 3)
  consumoPorUnidade       Decimal? @db.Decimal(10, 3)

  categoria   Categoria    @relation(fields: [categoriaId], references: [id])
  fornecedore Fornecedore? @relation(fields: [fornecedoreId], references: [id])
  loja        Loja         @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  // Relacionamento com estoque
  estoqueItens EstoqueItem[]

  @@index([lojaId])
  @@index([categoriaId])
  @@index([fornecedoreId])
  @@map("insumos")
}

model Cliente {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  nome        String
  email       String?
  telefone    String?
  cpfCnpj     String?
  endereco    String?
  cidade      String?
  estado      String?
  cep         String?
  observacoes String?
  lojaId      String

  loja       Loja        @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  orcamentos Orcamento[]

  @@index([lojaId])
  @@map("clientes")
}

model Orcamento {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  numero          String
  dataOrcamento   DateTime @default(now())
  clienteId       String
  descricao       String?
  observacoes     String?
  valorTotal      Decimal  @db.Decimal(10, 2)
  status          String   @default("rascunho")
  codigoAprovacao String?  @unique
  atendente       String?  @default("Equipe Comercial")
  formaPagamento  String?  @default("50% entrada, restante na entrega")
  prazoEntrega    String?  @default("10 a 15 dias úteis")
  lojaId          String

  cliente Cliente @relation(fields: [clienteId], references: [id])
  loja    Loja    @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@index([lojaId])
  @@index([clienteId])
  @@map("Orcamento")
}

model Maquina {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  nome      String
  descricao String?
  custoHora Decimal  @db.Decimal(10, 2)
  ativo     Boolean  @default(true)
  lojaId    String

  loja Loja @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@index([lojaId])
  @@map("Maquina")
}

model Funcao {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  nome        String
  descricao   String?
  salarioHora Decimal  @db.Decimal(10, 2)
  ativo       Boolean  @default(true)
  lojaId      String

  loja Loja @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@index([lojaId])
  @@map("Funcao")
}

model CustoIndireto {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  nome        String
  descricao   String?
  valorMensal Decimal  @db.Decimal(10, 2)
  ativo       Boolean  @default(true)
  lojaId      String

  loja Loja @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@index([lojaId])
  @@map("custos_indiretos")
}

model Produto {
  id               String   @id @default(uuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  nome             String
  descricao        String?
  categoria        String?
  largura          Decimal? @db.Decimal(10, 2)
  altura           Decimal? @db.Decimal(10, 2)
  area             Decimal? @db.Decimal(10, 2)
  unidadeMedida    String?
  quantidadePadrao Decimal? @db.Decimal(10, 2)
  horasProducao    Decimal? @db.Decimal(10, 2)
  custoTotal       Decimal? @db.Decimal(10, 2)
  precoVenda       Decimal? @db.Decimal(10, 2)
  margemLucro      Decimal? @db.Decimal(5, 2)
  ativo            Boolean  @default(true)
  lojaId           String

  loja Loja @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@index([lojaId])
  @@map("produtos")
}

model TipoMaterial {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  nome      String
  descricao String?
  ativo     Boolean  @default(true)
  lojaId    String

  loja Loja @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@index([lojaId])
  @@map("tipos_material")
}

model TemplateProduto {
  id                   String   @id @default(uuid())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  nome                 String
  categoria            String
  descricao            String?
  nomeServico          String
  descricaoProduto     String?
  horasProducao        Decimal  @db.Decimal(10, 2)
  larguraProduto       Decimal? @db.Decimal(10, 2)
  alturaProduto        Decimal? @db.Decimal(10, 2)
  areaProduto          Decimal? @db.Decimal(10, 2)
  unidadeMedidaProduto String?
  quantidadePadrao     Decimal? @db.Decimal(10, 2)
  ativo                Boolean  @default(true)
  lojaId               String

  loja Loja @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@unique([lojaId, nome])
  @@index([lojaId])
  @@index([lojaId, categoria])
  @@map("template_produtos")
}

model MensagemNegociacao {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orcamentoId String
  mensagem    String
  tipo        String
  lojaId      String

  loja Loja @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@index([lojaId])
  @@map("mensagens_negociacao")
}

model Notificacao {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  titulo    String
  mensagem  String
  tipo      String
  lida      Boolean  @default(false)
  lojaId    String

  loja Loja @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@index([lojaId])
  @@map("notificacoes")
}

// ===== MÓDULO DE ESTOQUE (INTEGRADO) =====

model EstoqueLocalizacao {
  id         String   @id @default(uuid())
  codigo     String   @unique // A1-01-B-02-03 (endereçamento hierárquico)
  deposito   String // Depósito principal
  corredor   String? // Corredor específico
  prateleira String? // Prateleira
  nivel      String? // Nível da prateleira
  posicao    String? // Posição específica
  descricao  String? // Descrição adicional
  capacidade Decimal? // Capacidade em unidades
  ativo      Boolean  @default(true)

  // Multi-tenant obrigatório (isolamento por loja)
  lojaId String
  loja   Loja   @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  // Relacionamentos
  estoques EstoqueItem[]

  // Timestamps para auditoria
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Índices obrigatórios para performance
  @@index([lojaId])
  @@index([codigo, lojaId])
  @@index([deposito, lojaId])
  @@map("estoque_localizacoes")
}

model EstoqueItem {
  id String @id @default(uuid())

  // FK para módulo de insumos (integração nativa com cadastro existente)
  insumoId String // Referência externa para evitar duplicação
  insumo   Insumo @relation(fields: [insumoId], references: [id])

  // FK para localização (interna)
  localizacaoId String
  localizacao   EstoqueLocalizacao @relation(fields: [localizacaoId], references: [id])

  // Quantidades (controle visível conforme premissas)
  quantidadeAtual     Decimal  @default(0) // Quantidade atual em estoque
  quantidadeReservada Decimal  @default(0) // Quantidade reservada para orçamentos
  estoqueMinimo       Decimal  @default(0) // Estoque mínimo para alertas
  estoqueMaximo       Decimal? // Estoque máximo (opcional)

  // Multi-tenant obrigatório (isolamento por loja)
  lojaId String
  loja   Loja   @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  // Relacionamentos
  movimentacoes EstoqueMovimentacao[]
  lotes         EstoqueLote[]

  // Timestamps para auditoria completa
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  dataUltimaMov DateTime? // Data da última movimentação

  @@unique([insumoId, localizacaoId, lojaId]) // Evitar duplicatas
  // Índices críticos para performance otimizada
  @@index([lojaId])
  @@index([insumoId, lojaId])
  @@index([localizacaoId])
  @@index([quantidadeAtual]) // Para consultas de estoque baixo
  @@map("estoque_itens")
}

model EstoqueMovimentacao {
  id String @id @default(uuid())

  // FK para estoque
  estoqueId String
  estoque   EstoqueItem @relation(fields: [estoqueId], references: [id])

  // Dados da movimentação (logs completos e rastreáveis)
  tipo                TipoMovimentacao
  quantidade          Decimal
  quantidadeAnterior  Decimal // Para auditoria
  quantidadePosterior Decimal // Para auditoria

  // Referências externas (opcionais para rastreabilidade)
  documentoRef String? // NF, OS, etc
  orcamentoId  String? // FK externa para orçamentos
  usuarioId    String // FK externa para usuários (auditoria)

  // Multi-tenant obrigatório (isolamento por loja)
  lojaId String
  loja   Loja   @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  // Timestamps e observações para logs completos
  dataMovimentacao DateTime @default(now())
  observacoes      String? // Observações da movimentação

  // Índices para performance e consultas otimizadas
  @@index([lojaId])
  @@index([estoqueId])
  @@index([dataMovimentacao])
  @@index([tipo, lojaId])
  @@index([usuarioId]) // Para auditoria por usuário
  @@map("estoque_movimentacoes")
}

model EstoqueLote {
  id String @id @default(uuid())

  // FK para estoque
  estoqueId String
  estoque   EstoqueItem @relation(fields: [estoqueId], references: [id])

  // Dados do lote (controle de validade conforme premissas)
  numeroLote     String
  dataFabricacao DateTime?
  dataValidade   DateTime? // Controle de validade
  quantidadeLote Decimal
  status         StatusLote @default(ATIVO)

  // Multi-tenant obrigatório (isolamento por loja)
  lojaId String
  loja   Loja   @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  // Timestamps para auditoria
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Índices para performance
  @@index([lojaId])
  @@index([estoqueId])
  @@index([dataValidade]) // Para relatórios de vencimento
  @@index([status, lojaId])
  @@index([numeroLote, lojaId])
  @@map("estoque_lotes")
}

// ===== ENUMS DO ESTOQUE =====

enum TipoMovimentacao {
  ENTRADA // Entrada de mercadoria
  SAIDA // Saída de mercadoria
  AJUSTE // Ajuste de estoque
  INVENTARIO // Inventário físico
  TRANSFERENCIA // Transferência entre localizações
}

enum StatusLote {
  ATIVO // Lote ativo
  VENCIDO // Lote vencido
  CONSUMIDO // Lote totalmente consumido
  BLOQUEADO // Lote bloqueado para uso
}

enum Role {
  ADMINISTRADOR
  FINANCEIRO
  PRODUCAO
  VENDAS
  ESTOQUE
}
