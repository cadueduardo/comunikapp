# =============================================================================
# ComunikApp - .env de PRODUÇÃO (template)
# =============================================================================
# IMPORTANTE:
#   1. NUNCA committar este arquivo com valores reais (somente o .example).
#   2. NUNCA reutilizar secrets de instalações antigas/comprometidas.
#   3. Gere secrets fortes com:  openssl rand -base64 48
#   4. Permissões: chmod 600 backend/.env  (apenas o usuário comunikapp lê).
# =============================================================================

# ----- Banco de dados (MySQL 8) -----
# Substitua usuário/senha/host. O usuário comunikapp_db deve ter acesso APENAS a este schema.
DATABASE_URL="mysql://comunikapp_db:TROCAR_SENHA_FORTE@127.0.0.1:3306/comunikapp"
ESTOQUE_DATABASE_URL="mysql://comunikapp_db:TROCAR_SENHA_FORTE@127.0.0.1:3306/comunikapp"

# ----- JWT -----
# Gere com:  openssl rand -base64 48
JWT_SECRET="TROCAR_GERAR_COM_OPENSSL_RAND_BASE64_48"
JWT_EXPIRES_IN="7d"

# ----- App -----
NODE_ENV=production
PORT=4001
HOST=127.0.0.1
TZ=America/Sao_Paulo
FRONTEND_URL="https://comunikapp.com.br"

# ----- Cadastro por convite -----
# Sem este valor, o cadastro publico fica bloqueado.
# Envie este codigo apenas para pessoas que podem criar uma nova conta/loja.
SIGNUP_INVITE_CODE="TROCAR_CODIGO_FORTE_DE_CONVITE"

# E-mails autorizados a acessar /platform/convites.
# Tambem recebem notificacao quando alguem solicita acesso pelo beta (landing).
# Nao usa o cargo ADMINISTRADOR da loja.
PLATFORM_ADMIN_ENABLED=true
PLATFORM_ADMIN_EMAILS="seu-email@dominio.com"

# Validade do convite gerado automaticamente pela landing (/beta), em dias.
BETA_INVITE_VALIDADE_DIAS=7

# Feedback beta (botao flutuante). Para desativar apos o beta: BETA_FEEDBACK_ENABLED=false
BETA_FEEDBACK_ENABLED=true
BETA_FEEDBACK_EMAIL="cadu.eduardo@gmail.com"

# CORS: em produção o Nginx é o único responsável; o backend NÃO envia headers CORS.
CORS_VIA_PROXY=true
# (Se um dia desligar o CORS via proxy, popular com origens permitidas separadas por vírgula)
# CORS_ORIGINS="https://comunikapp.com.br,https://www.comunikapp.com.br"

# ----- E-mail (SMTP) -----
# Use credenciais NOVAS, dedicadas a este app.
MAIL_HOST="smtp.seuprovedor.com"
MAIL_PORT=587
MAIL_USER="no-reply@comunikapp.com.br"
MAIL_PASS="TROCAR_SENHA_SMTP_NOVA"

# ----- Módulo de Estoque -----
ESTOQUE_MODULE_ENABLED=true
# Gere com:  openssl rand -hex 32
ESTOQUE_INTERNAL_API_TOKEN="TROCAR_GERAR_COM_OPENSSL_RAND_HEX_32"
ESTOQUE_ALLOWED_ROLES="ADMINISTRADOR,FINANCEIRO,ESTOQUE,VENDAS"
ESTOQUE_DB_CONNECTION_LIMIT=10
ESTOQUE_DB_POOL_TIMEOUT=20000
ESTOQUE_DB_POOL_IDLE_TIMEOUT=10000
ESTOQUE_DEFAULT_LIMIT=20
ESTOQUE_MAX_LIMIT=100
ESTOQUE_CACHE_DURATION=300
ESTOQUE_SLOW_QUERY_THRESHOLD=1000
ESTOQUE_HEALTH_CHECK_INTERVAL=30000
ESTOQUE_ENABLE_MONITORING=true
ESTOQUE_MAX_LOCATION_CODE_LENGTH=20
ESTOQUE_MAX_LOT_NUMBER_LENGTH=50
ESTOQUE_MAX_DOCUMENT_REF_LENGTH=100
ESTOQUE_MAX_OBSERVATIONS_LENGTH=255
ESTOQUE_ENABLE_LOW_STOCK_ALERTS=true
ESTOQUE_ENABLE_EXPIRY_ALERTS=true
ESTOQUE_ALERT_THRESHOLD=7
ESTOQUE_LOG_LEVEL="info"
ESTOQUE_ENABLE_QUERY_LOGS=false
ESTOQUE_ENABLE_PERFORMANCE_LOGS=true

# ----- Upload -----
UPLOAD_DEST="./uploads"
MAX_FILE_SIZE=5242880

# ----- Integrações externas (opcional; deixar vazio se não usado) -----
# Stripe - usar chaves NOVAS. Revogue as antigas no painel.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
