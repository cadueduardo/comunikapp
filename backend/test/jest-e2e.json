{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^otplib$": "<rootDir>/mocks/otplib.mock.ts",
    "^src/(.*)$": "<rootDir>/../src/$1"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!uuid/)"
  ]
}
